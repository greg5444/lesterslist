<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Submission <%= submission.SubmissionId %> — Admin</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
  <style>
    .detail-field { margin-bottom: 1.5rem; }
    .detail-label { font-weight: 600; color: #225675; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.3rem; }
    .detail-value { color: #333; font-size: 1rem; line-height: 1.6; padding: 0.75rem; background: #f9fbfc; border-radius: 4px; border-left: 3px solid #3D8C95; }
    .detail-value a { color: #3D8C95; text-decoration: underline; }
    .badge { display: inline-block; padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.78rem; font-weight: 600; text-transform: capitalize; }
    .badge-report    { background: #fde8e8; color: #b94040; }
    .badge-festival  { background: #e8f4f0; color: #2e7d5e; }
    .badge-band      { background: #eef4fb; color: #1a5997; }
    .badge-camp      { background: #fdf6e8; color: #8a6400; }
    .badge-venue     { background: #f3eefb; color: #6441a5; }
    .badge-photos    { background: #fef0e6; color: #b05c10; }
    .badge-pending   { background: #fff3cd; color: #856404; }
    .badge-reviewed  { background: #d4edda; color: #155724; }
    .badge-hidden    { background: #e2e3e5; color: #6c757d; }
    .action-btn { padding: 0.6rem 1.2rem; border: none; border-radius: 4px; cursor: pointer; font-size: 0.9rem; font-weight: 600; text-decoration: none; display: inline-block; margin-right: 0.5rem; }
    .btn-reviewed { background: #28a745; color: #fff; }
    .btn-hidden   { background: #6c757d; color: #fff; }
    .btn-pending  { background: #ffc107; color: #333; }
    .back-link { color: #3D8C95; text-decoration: none; font-weight: 600; margin-bottom: 1.5rem; display: inline-block; }
    .back-link:hover { color: #E6873C; }
  </style>
</head>
<body style="background: var(--color-background);">
  <header style="background: var(--color-secondary); color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin: 0; font-size: 1.5rem;">Admin — Submission #<%= submission.SubmissionId %></h1>
    <div>
      <span style="margin-right: 1.5rem;">Welcome, <%= username %></span>
      <a href="/admin/logout" style="color: var(--color-primary); text-decoration: underline;">Logout</a>
    </div>
  </header>

  <main style="max-width: 900px; margin: 2rem auto; padding: 0 1rem;">
    <div style="display: flex; gap: 2rem; align-items: flex-start;">
      <%- include('_sidebar') %>

      <div style="flex: 1; min-width: 0;">
        <a href="/admin/submissions?filter=<%= filter %>" class="back-link">← Back to Submissions</a>

        <div style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem;">

          <!-- Header Info -->
          <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid #eee;">
            <div>
              <h2 style="margin: 0 0 0.5rem 0; color: #225675;"><%= submission.label %></h2>
              <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                <span class="badge badge-<%= submission.SubmissionType %>"><%= submission.SubmissionType %></span>
                <span class="badge <%= submission.Status === 'Reviewed' ? 'badge-reviewed' : submission.Status === 'Hidden' ? 'badge-hidden' : 'badge-pending' %>"><%= submission.Status %></span>
                <span style="color: #999; font-size: 0.9rem;">Submitted: <%= new Date(submission.SubmittedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }) %></span>
              </div>
            </div>
            <div style="text-align: right;">
              <% if (submission.Status !== 'Reviewed') { %>
              <form method="POST" action="/admin/submissions/<%= submission.SubmissionId %>/status" style="display: inline;">
                <input type="hidden" name="status" value="Reviewed">
                <input type="hidden" name="filter" value="<%= filter %>">
                <button type="submit" class="action-btn btn-reviewed">✓ Mark Reviewed</button>
              </form>
              <% } %>
              <% if (submission.Status !== 'Hidden') { %>
              <form method="POST" action="/admin/submissions/<%= submission.SubmissionId %>/status" style="display: inline;">
                <input type="hidden" name="status" value="Hidden">
                <input type="hidden" name="filter" value="<%= filter %>">
                <button type="submit" class="action-btn btn-hidden">Hide</button>
              </form>
              <% } %>
            </div>
          </div>

          <!-- Submission Data -->
          <div style="margin-bottom: 2rem;">
            <% const isReport = submission.SubmissionType === 'report'; %>

            <% if (isReport) { %>
              <!-- Report Submission -->
              <% if (submission.data.SourceType && submission.data.SourceID) { %>
              <div class="detail-field">
                <div class="detail-label">Related Item</div>
                <div class="detail-value">
                  <strong><%= submission.data.SourceType.charAt(0).toUpperCase() + submission.data.SourceType.slice(1) %></strong>
                  <span style="color: #999;"> (#<%= submission.data.SourceID %>)</span>
                </div>
              </div>
              <% } %>

              <div class="detail-field">
                <div class="detail-label">Page URL</div>
                <div class="detail-value">
                  <% if (submission.data.PageURL) { %>
                    <a href="<%= submission.data.PageURL %>" target="_blank"><%= submission.data.PageURL %></a>
                  <% } else { %>
                    <span style="color: #999;">—</span>
                  <% } %>
                </div>
              </div>

              <div class="detail-field">
                <div class="detail-label">Problem Description</div>
                <div class="detail-value" style="white-space: pre-wrap; word-break: break-word;">
                  <%= submission.data.Description %>
                </div>
              </div>
            <% } else { %>
              <!-- Resource Submission - Table Format -->
              <table style="width: 100%; border-collapse: collapse; margin-bottom: 2rem;">
                <tbody>
                  <% Object.keys(submission.data).forEach((key, idx) => {
                    const value = submission.data[key];
                    if (!value || value === null || (typeof value === 'string' && value.trim() === '')) return;

                    let displayKey = key.replace(/([A-Z])/g, ' $1').trim();
                    displayKey = displayKey.charAt(0).toUpperCase() + displayKey.slice(1);
                  %>
                    <tr style="border-bottom: 1px solid #eee; <%= idx % 2 === 0 ? 'background: #fff;' : 'background: #f9fbfc;' %>">
                      <td style="padding: 0.75rem; font-weight: 600; color: #225675; width: 25%; vertical-align: top;"><%= displayKey %></td>
                      <td style="padding: 0.75rem; color: #333; word-break: break-word; white-space: pre-wrap;">
                        <% if (typeof value === 'string' && (value.startsWith('http://') || value.startsWith('https://'))) { %>
                          <a href="<%= value %>" target="_blank" style="color: #3D8C95; text-decoration: underline;"><%= value %></a>
                        <% } else if (key.includes('Date')) { %>
                          <%= new Date(value).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                        <% } else { %>
                          <%= value %>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>

          <!-- Contact Info -->
          <div style="background: #f9fbfc; padding: 1.5rem; border-radius: 6px; margin-bottom: 2rem;">
            <h3 style="margin: 0 0 1rem 0; color: #225675; font-size: 1rem;">Contact Information</h3>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
              <div>
                <div class="detail-label">Name</div>
                <div style="color: #333; font-weight: 600;"><%= submission.ContactName || '—' %></div>
              </div>
              <div>
                <div class="detail-label">Email</div>
                <% if (submission.ContactEmail) { %>
                  <a href="mailto:<%= submission.ContactEmail %>" style="color: #3D8C95; text-decoration: underline;"><%= submission.ContactEmail %></a>
                <% } else { %>
                  <span style="color: #999;">—</span>
                <% } %>
              </div>
              <div>
                <div class="detail-label">Phone</div>
                <div style="color: #333;"><%= submission.ContactPhone || '—' %></div>
              </div>
            </div>
          </div>

          <!-- Status Actions -->
          <div style="border-top: 1px solid #eee; padding-top: 1.5rem;">
            <h3 style="margin: 0 0 1rem 0; color: #225675; font-size: 1rem;">Update Status</h3>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              <% if (submission.Status !== 'Reviewed') { %>
              <form method="POST" action="/admin/submissions/<%= submission.SubmissionId %>/status" style="display: inline;">
                <input type="hidden" name="status" value="Reviewed">
                <input type="hidden" name="filter" value="<%= filter %>">
                <button type="submit" class="action-btn btn-reviewed">✓ Mark as Reviewed</button>
              </form>
              <% } %>
              <% if (submission.Status !== 'Hidden') { %>
              <form method="POST" action="/admin/submissions/<%= submission.SubmissionId %>/status" style="display: inline;">
                <input type="hidden" name="status" value="Hidden">
                <input type="hidden" name="filter" value="<%= filter %>">
                <button type="submit" class="action-btn btn-hidden">Hide Submission</button>
              </form>
              <% } %>
              <% if (submission.Status !== 'Pending') { %>
              <form method="POST" action="/admin/submissions/<%= submission.SubmissionId %>/status" style="display: inline;">
                <input type="hidden" name="status" value="Pending">
                <input type="hidden" name="filter" value="<%= filter %>">
                <button type="submit" class="action-btn btn-pending">Restore to Pending</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
