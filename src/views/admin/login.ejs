<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>
  <link rel="stylesheet" href="/css/main.css">
  <style>
    body { background: var(--color-background); display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .login-box { background: #fff; padding: 2.5rem; border-radius: 12px; box-shadow: 0 2px 12px rgba(34,86,117,0.08); max-width: 360px; width: 100%; }
  </style>
</head>
<body>
  <div class="login-box">
    <h1 style="color: var(--color-primary); margin-bottom: 1.5rem; text-align: center;">Admin Login</h1>
    <% if (error) { %>
      <div style="background: var(--color-primary); color: #fff; padding: 0.8rem; border-radius: 6px; margin-bottom: 1.2rem;"><%= error %></div>
    <% } %>
    <form method="POST" action="/admin/login" style="display: flex; flex-direction: column; gap: 1rem;">
      <input type="text" name="username" placeholder="Username" required style="padding: 0.8rem; border-radius: 5px; border: 1px solid #ccc;">
      <input type="password" name="password" placeholder="Password" required style="padding: 0.8rem; border-radius: 5px; border: 1px solid #ccc;">
      <button type="submit" style="padding: 0.8rem; background: var(--color-secondary); color: #fff; font-weight: 600; border: none; border-radius: 5px; cursor: pointer;">Login</button>
    </form>
  </div>
</body>
</html>

