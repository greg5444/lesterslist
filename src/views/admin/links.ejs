<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Short Link Manager - Admin</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
</head>
<body style="background: var(--color-background);">
  <header style="background: var(--color-secondary); color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
    <div>
      <h1 style="margin: 0; font-size: 1.5rem;">Short Link Manager</h1>
      <div style="color: rgba(255,255,255,0.8); font-size: 0.95rem; margin-top: 0.25rem;">Create and track custom redirects.</div>
    </div>
    <div>
      <a href="/admin/dashboard" style="color: #fff; text-decoration: underline; margin-right: 1.5rem;"><- Back to Dashboard</a>
      <a href="/admin/logout" style="color: var(--color-primary); text-decoration: underline;">Logout</a>
    </div>
  </header>

  <main style="max-width: 1100px; margin: 2.5rem auto; padding: 0 1rem;">
    <div style="display: flex; gap: 2rem; align-items: flex-start;">
      <%- include('_sidebar') %>
      <div style="flex: 1; min-width: 0;">
        <% if (success) { %>
          <div style="background: #d4edda; border: 1px solid #c3e6cb; color: #155724; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;">Link Created!</div>
        <% } %>
        <% if (error) { %>
          <div style="background: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem;"><%= error %></div>
        <% } %>

        <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem; margin-bottom: 2rem;">
          <h2 style="color: var(--color-primary); margin: 0 0 1.2rem 0;">Create Link</h2>
          <form action="/admin/links" method="POST" style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;">
            <div style="display: flex; align-items: center; flex: 1; min-width: 260px;">
              <span style="background: #f1f3f5; border: 1px solid #ddd; border-right: 0; padding: 0.75rem 0.9rem; border-radius: 8px 0 0 8px; font-size: 0.9rem; color: #666; white-space: nowrap;"><%= baseUrl.replace(/^https?:\/\//, '') %>/</span>
              <input type="text" name="slug" placeholder="your-slug" required style="flex: 1; padding: 0.75rem; border: 1px solid #ddd; border-radius: 0 8px 8px 0; font-size: 0.95rem;">
            </div>
            <input type="url" name="targetURL" placeholder="https://..." required style="flex: 2; min-width: 260px; padding: 0.75rem; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem;">
            <button type="submit" style="background: var(--color-primary); color: #fff; font-weight: 700; border: none; padding: 0.8rem 1.6rem; font-size: 1rem; border-radius: 8px; cursor: pointer; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Create Link</button>
          </form>
        </section>

        <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem;">
          <h2 style="color: var(--color-primary); margin: 0 0 1.2rem 0;">Links</h2>
          <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse; border: 1px solid #e1e5ea;">
              <thead>
                <tr style="background: var(--color-primary); color: #fff;">
                  <th style="padding: 0.9rem; text-align: left;">Short Link</th>
                  <th style="padding: 0.9rem; text-align: left;">Target</th>
                  <th style="padding: 0.9rem; text-align: left; width: 130px;">Stats</th>
                  <th style="padding: 0.9rem; text-align: right; width: 120px;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!links || links.length === 0) { %>
                  <tr>
                    <td colspan="4" style="padding: 1rem; color: #777;">No links yet.</td>
                  </tr>
                <% } else { %>
                  <% links.forEach((link, index) => { %>
                    <tr style="border-bottom: 1px solid #e9ecef; <%= index % 2 === 0 ? 'background: #f8f9fa;' : '' %>">
                      <td style="padding: 0.85rem;">
                        <div style="display: flex; align-items: center; gap: 0.6rem;">
                          <a href="<%= baseUrl %>/<%= link.Slug %>" target="_blank" style="color: var(--color-secondary); text-decoration: underline;"><%= baseUrl.replace(/^https?:\/\//, '') %>/<%= link.Slug %></a>
                          <button type="button" class="copy-link" data-url="<%= baseUrl %>/<%= link.Slug %>" title="Copy link" style="border: 1px solid #d0d7de; background: #fff; color: #225675; border-radius: 6px; padding: 0.3rem 0.45rem; cursor: pointer;">
                            <i class="fa-solid fa-copy"></i>
                          </button>
                        </div>
                      </td>
                      <td style="padding: 0.85rem; max-width: 380px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <a href="<%= link.TargetURL %>" target="_blank" style="color: #555;"><%= link.TargetURL %></a>
                      </td>
                      <td style="padding: 0.85rem;">
                        <span style="display: inline-block; background: #17a2b8; color: #fff; padding: 0.25rem 0.6rem; border-radius: 999px; font-size: 0.85rem; font-weight: 600;"><%= link.ClickCount || 0 %> Clicks</span>
                      </td>
                      <td style="padding: 0.85rem; text-align: right;">
                        <form method="POST" action="/admin/links/delete/<%= link.id %>" style="display: inline;">
                          <button type="submit" onclick="return confirm('Are you sure?')" style="background: #d9534f; color: #fff; border: none; padding: 0.45rem 0.9rem; border-radius: 6px; cursor: pointer;">Delete</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </div>
  </main>

  <script>
    function copyText(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text);
      }
      const temp = document.createElement('textarea');
      temp.value = text;
      temp.setAttribute('readonly', '');
      temp.style.position = 'absolute';
      temp.style.left = '-9999px';
      document.body.appendChild(temp);
      temp.select();
      document.execCommand('copy');
      document.body.removeChild(temp);
      return Promise.resolve();
    }

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.copy-link').forEach(function(button) {
        button.addEventListener('click', function() {
          const url = button.getAttribute('data-url');
          copyText(url).then(function() {
            button.style.background = '#e6ffed';
            button.style.borderColor = '#2ea043';
            setTimeout(function() {
              button.style.background = '#fff';
              button.style.borderColor = '#d0d7de';
            }, 800);
          });
        });
      });
    });
  </script>
</body>
</html>
