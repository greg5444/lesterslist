<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Submissions — Admin</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
  <style>
    .sub-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .sub-table th { background: #225675; color: #fff; padding: 0.75rem 1rem; text-align: left; font-weight: 600; white-space: nowrap; }
    .sub-table td { padding: 0.75rem 1rem; border-bottom: 1px solid #eee; vertical-align: top; }
    .sub-table tr:hover td { background: #f9fbfc; }
    .badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.78rem; font-weight: 600; text-transform: capitalize; }
    .badge-report    { background: #fde8e8; color: #b94040; }
    .badge-festival  { background: #e8f4f0; color: #2e7d5e; }
    .badge-band      { background: #eef4fb; color: #1a5997; }
    .badge-camp      { background: #fdf6e8; color: #8a6400; }
    .badge-venue     { background: #f3eefb; color: #6441a5; }
    .badge-photos    { background: #fef0e6; color: #b05c10; }
    .badge-pending   { background: #fff3cd; color: #856404; }
    .badge-reviewed  { background: #d4edda; color: #155724; }
    .badge-hidden    { background: #e2e3e5; color: #6c757d; }
    .action-btn { padding: 0.3rem 0.75rem; border: none; border-radius: 4px; cursor: pointer; font-size: 0.82rem; font-weight: 600; text-decoration: none; display: inline-block; }
    .btn-reviewed { background: #28a745; color: #fff; }
    .btn-hidden   { background: #6c757d; color: #fff; }
    .btn-pending  { background: #ffc107; color: #333; }
    .filter-tab { padding: 0.5rem 1.2rem; border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: background 0.15s; }
    .filter-tab-active   { background: #225675; color: #fff; }
    .filter-tab-inactive { background: #f0f0f0; color: #444; }
    .filter-tab-inactive:hover { background: #e0e0e0; }
    .detail-row { font-size: 0.8rem; color: #888; margin-top: 0.25rem; line-height: 1.4; }
  </style>
</head>
<body style="background: var(--color-background);">
  <header style="background: var(--color-secondary); color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin: 0; font-size: 1.5rem;">Admin — Submissions</h1>
    <div>
      <span style="margin-right: 1.5rem;">Welcome, <%= username %></span>
      <a href="/admin/logout" style="color: var(--color-primary); text-decoration: underline;">Logout</a>
    </div>
  </header>

  <main style="max-width: 1200px; margin: 2.5rem auto; padding: 0 1rem;">
    <div style="display: flex; gap: 2rem; align-items: flex-start;">
      <%- include('_sidebar') %>

      <div style="flex: 1; min-width: 0;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.75rem;">
          <h2 style="margin: 0; color: #225675;">Resource Submissions & Reports</h2>
          <a href="/admin/dashboard" style="color: #888; font-size: 0.9rem; text-decoration: none;">&larr; Back to Dashboard</a>
        </div>

        <!-- Filter Tabs -->
        <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
          <a href="/admin/submissions?filter=all"
             class="filter-tab <%= filter === 'all' ? 'filter-tab-active' : 'filter-tab-inactive' %>">
            All
          </a>
          <a href="/admin/submissions?filter=submissions"
             class="filter-tab <%= filter === 'submissions' ? 'filter-tab-active' : 'filter-tab-inactive' %>">
            User Submissions
          </a>
          <a href="/admin/submissions?filter=reports"
             class="filter-tab <%= filter === 'reports' ? 'filter-tab-active' : 'filter-tab-inactive' %>">
            Problem Reports
          </a>
        </div>

        <div style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); overflow: hidden;">
          <% if (submissions.length === 0) { %>
            <div style="padding: 3rem; text-align: center; color: #888;">
              No submissions found.
            </div>
          <% } else { %>
          <div style="overflow-x: auto;">
            <table class="sub-table">
              <thead>
                <tr>
                  <th style="width: 50px;">#</th>
                  <th style="width: 90px;">Type</th>
                  <th>Item / Description</th>
                  <th>Contact</th>
                  <th style="width: 110px;">Date</th>
                  <th style="width: 90px;">Status</th>
                  <th style="width: 160px;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% submissions.forEach(s => {
                  const isReport = s.SubmissionType === 'report';
                  const dateStr = new Date(s.SubmittedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                  const statusClass = s.Status === 'Reviewed' ? 'badge-reviewed' : s.Status === 'Hidden' ? 'badge-hidden' : 'badge-pending';
                %>
                <tr>
                  <td style="color: #aaa; font-size: 0.8rem;"><%= s.SubmissionId %></td>
                  <td>
                    <span class="badge badge-<%= s.SubmissionType %>"><%= s.SubmissionType %></span>
                  </td>
                  <td>
                    <div style="font-weight: 600; color: #222;"><%= s.label %></div>
                    <% if (isReport && s.data.Description) { %>
                      <div class="detail-row"><%= s.data.Description.substring(0, 120) %><%= s.data.Description.length > 120 ? '…' : '' %></div>
                    <% } else if (!isReport) { %>
                      <%
                        const extras = [];
                        if (s.data.City && s.data.State) extras.push(`${s.data.City}, ${s.data.State}`);
                        else if (s.data.HomeCity && s.data.HomeState) extras.push(`${s.data.HomeCity}, ${s.data.HomeState}`);
                        if (s.data.StartDate) extras.push(new Date(s.data.StartDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }));
                        if (s.data.SubmissionType) extras.push(s.data.SubmissionType);
                      %>
                      <% if (extras.length) { %>
                        <div class="detail-row"><%= extras.join(' &middot; ') %></div>
                      <% } %>
                    <% } %>
                  </td>
                  <td>
                    <% if (s.ContactName) { %><div style="font-weight: 600; font-size: 0.85rem;"><%= s.ContactName %></div><% } %>
                    <% if (s.ContactEmail) { %><div class="detail-row"><a href="mailto:<%= s.ContactEmail %>" style="color: #3D8C95;"><%= s.ContactEmail %></a></div><% } %>
                    <% if (s.ContactPhone) { %><div class="detail-row"><%= s.ContactPhone %></div><% } %>
                  </td>
                  <td style="font-size: 0.85rem; color: #666; white-space: nowrap;"><%= dateStr %></td>
                  <td>
                    <span class="badge <%= statusClass %>"><%= s.Status %></span>
                  </td>
                  <td>
                    <a href="/admin/submissions/<%= s.SubmissionId %>?filter=<%= filter %>" style="display: inline-block; padding: 0.3rem 0.75rem; background: #225675; color: #fff; border-radius: 4px; text-decoration: none; font-size: 0.82rem; font-weight: 600; margin-right: 0.3rem;" title="View submission details">View</a>
                    <% if (s.Status !== 'Reviewed') { %>
                    <form method="POST" action="/admin/submissions/<%= s.SubmissionId %>/status" style="display: inline;">
                      <input type="hidden" name="status" value="Reviewed">
                      <input type="hidden" name="filter" value="<%= filter %>">
                      <button type="submit" class="action-btn btn-reviewed" title="Mark as Reviewed">&#10003; Reviewed</button>
                    </form>
                    <% } %>
                    <% if (s.Status !== 'Hidden') { %>
                    <form method="POST" action="/admin/submissions/<%= s.SubmissionId %>/status" style="display: inline; margin-left: 0.3rem;">
                      <input type="hidden" name="status" value="Hidden">
                      <input type="hidden" name="filter" value="<%= filter %>">
                      <button type="submit" class="action-btn btn-hidden" title="Hide this submission">Hide</button>
                    </form>
                    <% } %>
                    <% if (s.Status !== 'Pending') { %>
                    <form method="POST" action="/admin/submissions/<%= s.SubmissionId %>/status" style="display: inline; margin-left: 0.3rem;">
                      <input type="hidden" name="status" value="Pending">
                      <input type="hidden" name="filter" value="<%= filter %>">
                      <button type="submit" class="action-btn btn-pending" title="Restore to Pending">Restore</button>
                    </form>
                    <% } %>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </div>

        <p style="color: #aaa; font-size: 0.8rem; margin-top: 1rem;">
          Showing <%= submissions.length %> record<%= submissions.length !== 1 ? 's' : '' %>.
        </p>
      </div>
    </div>
  </main>
</body>
</html>
