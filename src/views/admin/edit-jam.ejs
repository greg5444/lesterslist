<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Jam - Admin</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
</head>
<body style="background: #f5f5f5;">
  <header style="background: #225675; color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin: 0; font-size: 1.5rem;">Edit Jam</h1>
    <div>
      <a href="/admin/dashboard" style="color: #3D8C95; text-decoration: underline; margin-right: 1.5rem;">← Back to Dashboard</a>
      <span style="margin-right: 1.5rem;">Welcome, <%= username %></span>
      <a href="/admin/logout" style="color: #3D8C95; text-decoration: underline;">Logout</a>
    </div>
  </header>
  <main style="max-width: 1100px; margin: 2.5rem auto; padding: 0 1rem;">
    <div style="display: flex; gap: 2rem; align-items: flex-start;">
      <%- include('_sidebar') %>
      <div style="flex: 1; min-width: 0;">
        <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem; max-width: 700px;">
          <form method="POST" action="/admin/edit/jam/<%= jam.JamID %>" style="display: flex; flex-direction: column; gap: 1.2rem;">
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">Jam Name *</label>
          <input type="text" name="JamName" value="<%= jam.JamName || '' %>" required style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">Venue Name *</label>
          <input type="text" name="VenueName" value="<%= jam.VenueName || '' %>" required style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">Schedule *</label>
          <textarea name="Schedule" required style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc; min-height: 100px; resize: vertical;" placeholder="Tell us: When it meets, how often, what days/times, what to expect"><%= jam.Schedule || '' %></textarea>
        </div>
        
        <div style="background: #f5f5f5; padding: 1rem; border-radius: 5px;">
          <h3 style="margin: 0 0 0.75rem 0; color: #225675; font-size: 1rem;">Jam Level (select all that apply)</h3>
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; margin-bottom: 0.5rem;">
            <input type="checkbox" name="AllWelcome" value="1" <%= jam.AllWelcome ? 'checked' : '' %> style="width: 18px; height: 18px;">
            <span style="color: #555; font-size: 0.95rem;">All Jammers Welcome</span>
          </label>
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; margin-bottom: 0.5rem;">
            <input type="checkbox" name="BeginnersWelcome" value="1" <%= jam.BeginnersWelcome ? 'checked' : '' %> style="width: 18px; height: 18px;">
            <span style="color: #555; font-size: 0.95rem;">Beginners Welcome</span>
          </label>
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="checkbox" name="AdvancedOnly" value="1" <%= jam.AdvancedOnly ? 'checked' : '' %> style="width: 18px; height: 18px;">
            <span style="color: #555; font-size: 0.95rem;">Advanced Player Jam</span>
          </label>
        </div>
        
        <div style="background: #f5f5f5; padding: 1rem; border-radius: 5px;">
          <h3 style="margin: 0 0 0.75rem 0; color: #225675; font-size: 1rem;">Contact Information</h3>
          
          <div style="margin-bottom: 0.75rem;">
            <label style="display: block; font-weight: 600; color: #555; margin-bottom: 0.5rem;">Contact Name *</label>
            <input type="text" name="ContactName" value="<%= jam.ContactName || '' %>" required style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
          </div>
          
          <div style="margin-bottom: 0.75rem;">
            <label style="display: block; font-weight: 600; color: #555; margin-bottom: 0.5rem;">Contact Email *</label>
            <input type="email" name="ContactEmail" value="<%= jam.ContactEmail || '' %>" required style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
          </div>
          
          <div style="margin-bottom: 0.75rem;">
            <label style="display: block; font-weight: 600; color: #555; margin-bottom: 0.5rem;">Contact Phone *</label>
            <input type="tel" name="ContactPhone" value="<%= jam.ContactPhone || '' %>" required style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
          </div>
          
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <input type="checkbox" name="ShowPhone" value="1" <%= jam.ShowPhone ? 'checked' : '' %> style="width: 18px; height: 18px;">
            <span style="color: #555; font-size: 0.9rem;">Show phone number publicly on the listing</span>
          </label>
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">City</label>
          <input type="text" name="City" value="<%= jam.City || '' %>" style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">State</label>
          <input type="text" name="State" value="<%= jam.State || '' %>" style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">Zip Code</label>
          <input type="text" name="Zip" value="<%= jam.Zip || '' %>" style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">Google Maps Address</label>
          <input type="text" name="GoogleMapAddress" value="<%= jam.GoogleMapAddress || '' %>" placeholder="Full address for Google Maps" style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 1rem;">
          <button type="submit" style="flex: 1; padding: 0.8rem; background: #3D8C95; color: #fff; font-weight: 600; border: none; border-radius: 5px; cursor: pointer;">Save Changes</button>
          <a href="/admin/dashboard" style="flex: 1; padding: 0.8rem; background: #6c757d; color: #fff; font-weight: 600; border: none; border-radius: 5px; cursor: pointer; text-align: center; text-decoration: none; display: block;">Cancel</a>
        </div>
          </form>
        </section>
      </div>
    </div>
  </main>
</body>
</html>
