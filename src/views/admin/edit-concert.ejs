<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title %> - Admin</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
</head>
<body style="background: #f5f5f5;">
  <header style="background: #225675; color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin: 0; font-size: 1.5rem;">Edit Concert</h1>
    <div>
      <a href="/concerts/<%= concert.ConcertNumber %>" style="color: #3D8C95; text-decoration: underline; margin-right: 1.5rem;" target="_blank">View Public Page ↗</a>
      <a href="/admin/dashboard" style="color: #3D8C95; text-decoration: underline; margin-right: 1.5rem;">← Dashboard</a>
      <span style="margin-right: 1.5rem;">Welcome, <%= username %></span>
      <a href="/admin/logout" style="color: #3D8C95; text-decoration: underline;">Logout</a>
    </div>
  </header>
  <main style="max-width: 1100px; margin: 2.5rem auto; padding: 0 1rem;">
    <div style="display: flex; gap: 2rem; align-items: flex-start;">
      <%- include('_sidebar') %>
      <div style="flex: 1; min-width: 0;">

        <% if (saved) { %>
          <div style="background:#d4edda;color:#155724;border:1px solid #c3e6cb;border-radius:6px;padding:0.75rem 1rem;margin-bottom:1rem;font-weight:600;">
            ✅ Changes saved successfully.
          </div>
        <% } %>

        <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem; max-width: 700px;">
          <h2 style="margin:0 0 1.5rem 0;color:#225675;font-size:1.2rem;"><%= concert.ConcertName %> <span style="color:#888;font-size:0.85rem;font-weight:400;">#<%= concert.ConcertNumber %></span></h2>

          <form method="POST" action="/admin/edit/concert/<%= concert.ConcertNumber %>" style="display: flex; flex-direction: column; gap: 1.2rem;">

            <div>
              <label style="display:block;font-weight:600;color:#225675;margin-bottom:0.5rem;">Concert Name *</label>
              <input type="text" name="ConcertName" value="<%= concert.ConcertName || '' %>" required
                style="width:100%;padding:0.7rem;border-radius:5px;border:1px solid #ccc;box-sizing:border-box;">
            </div>

            <div style="color:#888;font-size:0.9rem;">
              Date: <strong><%= concert.ConcertDate ? new Date(concert.ConcertDate).toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric',timeZone:'UTC'}) : '—' %></strong>
            </div>

            <%# Image URL + Alignment %>
            <div style="background:#f0f7fb;border:1px solid #c7dce9;border-radius:8px;padding:1.2rem;">
              <h3 style="margin:0 0 1rem 0;color:#225675;font-size:1rem;">Concert Image <small style="color:#666;font-weight:400;">(overrides the band photo for this show)</small></h3>

              <div style="margin-bottom:0.75rem;">
                <label style="display:block;font-weight:600;color:#555;margin-bottom:0.4rem;">Concert Image URL</label>
                <input type="url" id="imageUrlInput" name="ConcertImage" value="<%= concert.ConcertImage || '' %>"
                  placeholder="https://... (leave blank to use band photo)"
                  style="width:100%;padding:0.7rem;border-radius:5px;border:1px solid #ccc;box-sizing:border-box;"
                  oninput="updatePreview()">
                <small style="color:#888;font-size:0.8rem;">Do not include # in the URL — set the alignment below.</small>
              </div>

              <div style="margin-bottom:1rem;">
                <label style="display:block;font-weight:600;color:#555;margin-bottom:0.4rem;">Image Position (crop anchor)</label>
                <select id="alignmentSelect" name="ImageAlignment"
                  style="padding:0.6rem 1rem;border-radius:5px;border:1px solid #ccc;font-size:0.95rem;background:#fff;"
                  onchange="updatePreview()">
                  <option value="top"    <%= imageAlignment === 'top'    ? 'selected' : '' %>>Top — show top of image (default)</option>
                  <option value="center" <%= imageAlignment === 'center' ? 'selected' : '' %>>Center — show middle of image</option>
                  <option value="bottom" <%= imageAlignment === 'bottom' ? 'selected' : '' %>>Bottom — show bottom of image</option>
                </select>
              </div>

              <div>
                <div style="font-weight:600;color:#555;font-size:0.85rem;margin-bottom:0.4rem;">Preview (gallery card size):</div>
                <div style="width:220px;height:220px;border-radius:8px;overflow:hidden;background:#eee;border:1px solid #ddd;">
                  <img id="imgPreview"
                    src="<%= concert.ConcertImage || '' %>"
                    onerror="this.src='https://images.lesterslist.com/media/lesterlogo_sq.png'"
                    style="width:100%;height:100%;object-fit:cover;object-position:<%= imageAlignment %>;">
                </div>
              </div>
            </div>

            <div style="display:flex;gap:1rem;margin-top:0.5rem;">
              <button type="submit"
                style="flex:1;padding:0.8rem;background:#3D8C95;color:#fff;font-weight:600;border:none;border-radius:5px;cursor:pointer;font-size:1rem;">
                Save Changes
              </button>
              <a href="/concerts/<%= concert.ConcertNumber %>"
                style="flex:1;padding:0.8rem;background:#6c757d;color:#fff;font-weight:600;border:none;border-radius:5px;cursor:pointer;text-align:center;text-decoration:none;display:block;">
                Cancel
              </a>
            </div>
          </form>
        </section>
      </div>
    </div>
  </main>

  <script>
    function updatePreview() {
      const url = document.getElementById('imageUrlInput').value.trim();
      const align = document.getElementById('alignmentSelect').value;
      const img = document.getElementById('imgPreview');
      img.src = url || 'https://images.lesterslist.com/media/lesterlogo_sq.png';
      img.style.objectPosition = align;
    }
  </script>
</body>
</html>
