<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Learning Resource - Admin</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
</head>
<body style="background: #f5f5f5;">
  <header style="background: #225675; color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin: 0; font-size: 1.5rem;">Edit Learning Resource</h1>
    <div>
      <a href="/admin/dashboard" style="color: #3D8C95; text-decoration: underline; margin-right: 1.5rem;">← Back to Dashboard</a>
      <span style="margin-right: 1.5rem;">Welcome, <%= username %></span>
      <a href="/admin/logout" style="color: #3D8C95; text-decoration: underline;">Logout</a>
    </div>
  </header>
  <main style="max-width: 1100px; margin: 2.5rem auto; padding: 0 1rem;">
    <div style="display: flex; gap: 2rem; align-items: flex-start;">
      <%- include('_sidebar') %>
      <div style="flex: 1; min-width: 0;">
        <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem; max-width: 700px;">
          <form method="POST" action="/admin/edit/learn/<%= resource.id %>" style="display: flex; flex-direction: column; gap: 1.2rem;">
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">Instructor/Course Name *</label>
          <input type="text" name="InstructorName" value="<%= resource.InstructorName || '' %>" required style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">Course Description *</label>
          <textarea name="CourseDescription" required style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc; min-height: 120px; resize: vertical;"><%= resource.CourseDescription || '' %></textarea>
        </div>
        
        <div>
          <label style="display: block; font-weight: 600; color: #225675; margin-bottom: 0.5rem;">External Link *</label>
          <input type="url" name="ExternalLink" value="<%= resource.ExternalLink || '' %>" required placeholder="https://" style="width: 100%; padding: 0.7rem; border-radius: 5px; border: 1px solid #ccc;">
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 1rem;">
          <button type="submit" style="flex: 1; padding: 0.8rem; background: #3D8C95; color: #fff; font-weight: 600; border: none; border-radius: 5px; cursor: pointer;">Save Changes</button>
          <a href="/admin/dashboard" style="flex: 1; padding: 0.8rem; background: #6c757d; color: #fff; font-weight: 600; border: none; border-radius: 5px; cursor: pointer; text-align: center; text-decoration: none; display: block;">Cancel</a>
        </div>
          </form>
        </section>
      </div>
    </div>
  </main>
</body>
</html>
