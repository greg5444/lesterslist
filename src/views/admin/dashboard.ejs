<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
</head>
<body style="background: var(--color-background);">
  <header style="background: var(--color-secondary); color: #fff; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center;">
    <h1 style="margin: 0; font-size: 1.5rem;">Admin Dashboard</h1>
    <div>
      <span style="margin-right: 1.5rem;">Welcome, <%= username %></span>
      <a href="/admin/logout" style="color: var(--color-primary); text-decoration: underline;">Logout</a>
    </div>
  </header>
  <main style="max-width: 1100px; margin: 2.5rem auto; padding: 0 1rem;">
    <div style="display: flex; gap: 2rem; align-items: flex-start;">
      <%- include('_sidebar') %>
      <div style="flex: 1; min-width: 0;">
        <!-- Quick Actions -->
        <section style="margin-bottom: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="/bands" target="_blank" style="display: inline-block; background: #225675; color: #fff; font-weight: 700; border-radius: 8px; padding: 1rem 2rem; font-size: 1rem; text-decoration: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            🌐 Browse & Edit Site
          </a>
          <a href="/admin/ticker" style="display: inline-block; background: var(--color-highlight-orange); color: #fff; font-weight: 700; border-radius: 8px; padding: 1rem 2rem; font-size: 1rem; text-decoration: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            🎬 Manage Homepage Ticker
          </a>
          <a href="/admin/links" style="display: inline-block; background: var(--color-primary-teal); color: #fff; font-weight: 700; border-radius: 8px; padding: 1rem 2rem; font-size: 1rem; text-decoration: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            🔗 Short Link Manager
          </a>
        </section>
        
        <!-- Quick Stats -->
        <section style="display: flex; gap: 1rem; margin-bottom: 2.5rem; flex-wrap: wrap;">
          <div style="flex: 1; min-width: 130px; background: var(--color-primary); color: #fff; padding: 1.5rem; border-radius: 10px; text-align: center;">
            <div style="font-size: 2.5rem; font-weight: 700;"><%= stats.bands %></div>
            <div style="font-size: 0.95rem;">Bands</div>
          </div>
          <div style="flex: 1; min-width: 130px; background: var(--color-secondary); color: #fff; padding: 1.5rem; border-radius: 10px; text-align: center;">
            <div style="font-size: 2.5rem; font-weight: 700;"><%= stats.concerts %></div>
            <div style="font-size: 0.95rem;">Concerts</div>
          </div>
          <div style="flex: 1; min-width: 130px; background: var(--color-primary); color: #fff; padding: 1.5rem; border-radius: 10px; text-align: center;">
            <div style="font-size: 2.5rem; font-weight: 700;"><%= stats.festivals %></div>
            <div style="font-size: 0.95rem;">Festivals</div>
          </div>
          <a href="/admin/submissions?filter=submissions" style="flex: 1; min-width: 130px; background: #225675; color: #fff; padding: 1.5rem; border-radius: 10px; text-align: center; text-decoration: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            <div style="font-size: 2.5rem; font-weight: 700;"><%= stats.pendingSubmissions %></div>
            <div style="font-size: 0.95rem; line-height: 1.3;">Pending<br>Submissions</div>
          </a>
          <a href="/admin/submissions?filter=reports" style="flex: 1; min-width: 130px; background: #b94040; color: #fff; padding: 1.5rem; border-radius: 10px; text-align: center; text-decoration: none; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
            <div style="font-size: 2.5rem; font-weight: 700;"><%= stats.pendingReports %></div>
            <div style="font-size: 0.95rem; line-height: 1.3;">Problem<br>Reports</div>
          </a>
        </section>
        <!-- Approval Queue -->
        <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem; margin-bottom: 2rem;">
      <h2 style="color: var(--color-primary); margin-bottom: 1.2rem;">Approval Queue: Local Jams – Find Your Circle</h2>
      <% if (draftJams.length === 0) { %>
        <div style="color: #888;">No pending jams.</div>
      <% } else { %>
        <ul style="list-style: none; padding: 0;">
          <% draftJams.forEach(jam => { %>
            <li style="background: #f8f9fa; border-radius: 6px; margin-bottom: 1rem; padding: 1rem; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <div style="font-weight: 600; color: var(--color-secondary);"><%= jam.JamName %></div>
                <div style="color: #555; font-size: 0.95rem;">Venue: <%= jam.VenueName %></div>
                <% if (jam.City && jam.State) { %>
                  <div style="color: #555; font-size: 0.95rem;">Location: <%= jam.City %>, <%= jam.State %></div>
                <% } %>
                <div style="color: #555; font-size: 0.95rem;">Schedule: <%= jam.Schedule %></div>
                <% if (jam.AllWelcome || jam.BeginnersWelcome || jam.AdvancedOnly) { %>
                  <div style="color: #555; font-size: 0.9rem; margin-top: 0.3rem;">
                    <strong>Level:</strong>
                    <% if (jam.AllWelcome) { %><span style="background: #28a745; color: #fff; padding: 0.2rem 0.5rem; border-radius: 3px; font-size: 0.85rem; margin-left: 0.3rem;">All Welcome</span><% } %>
                    <% if (jam.BeginnersWelcome) { %><span style="background: #17a2b8; color: #fff; padding: 0.2rem 0.5rem; border-radius: 3px; font-size: 0.85rem; margin-left: 0.3rem;">Beginners</span><% } %>
                    <% if (jam.AdvancedOnly) { %><span style="background: #E6873C; color: #fff; padding: 0.2rem 0.5rem; border-radius: 3px; font-size: 0.85rem; margin-left: 0.3rem;">Advanced</span><% } %>
                  </div>
                <% } %>
                <div style="color: #888; font-size: 0.95rem; margin-top: 0.5rem;">
                  <strong>Contact:</strong> <%= jam.ContactName %><br>
                  <strong>Email:</strong> <%= jam.ContactEmail %><br>
                  <strong>Phone:</strong> <%= jam.ContactPhone %><% if (jam.ShowPhone) { %> (will be shown publicly)<% } else { %> (private)<% } %>
                </div>
              </div>
              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <a href="/admin/edit/jam/<%= jam.JamID %>" style="padding: 0.5rem 1rem; background: #3D8C95; color: #fff; border: none; border-radius: 5px; cursor: pointer; text-decoration: none; display: inline-block;">Edit</a>
                <form method="POST" action="/admin/approve/jam/<%= jam.JamID %>" style="display: inline;">
                  <button type="submit" style="padding: 0.5rem 1rem; background: #28a745; color: #fff; border: none; border-radius: 5px; cursor: pointer;">Approve</button>
                </form>
                <form method="POST" action="/admin/delete/jam/<%= jam.JamID %>" style="display: inline;">
                  <button type="submit" style="padding: 0.5rem 1rem; background: #d9534f; color: #fff; border: none; border-radius: 5px; cursor: pointer;" onclick="return confirm('Are you sure you want to delete this jam?');">Delete</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
      </section>
      <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem;">
      <h2 style="color: var(--color-primary); margin-bottom: 1.2rem;">Approval Queue: Learn Resources</h2>
      <% if (draftLearn.length === 0) { %>
        <div style="color: #888;">No pending resources.</div>
      <% } else { %>
        <ul style="list-style: none; padding: 0;">
          <% draftLearn.forEach(resource => { %>
            <li style="background: #f8f9fa; border-radius: 6px; margin-bottom: 1rem; padding: 1rem; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <div style="font-weight: 600; color: var(--color-secondary);"><%= resource.InstructorName %></div>
                <div style="color: #555; font-size: 0.95rem;">Description: <%= resource.CourseDescription %></div>
                <div style="color: #555; font-size: 0.95rem;">Link: <a href="<%= resource.ExternalLink %>" target="_blank" style="color: var(--color-primary);"><%= resource.ExternalLink %></a></div>
              </div>
              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <a href="/admin/edit/learn/<%= resource.id %>" style="padding: 0.5rem 1rem; background: #3D8C95; color: #fff; border: none; border-radius: 5px; cursor: pointer; text-decoration: none; display: inline-block;">Edit</a>
                <form method="POST" action="/admin/approve/learn/<%= resource.id %>" style="display: inline;">
                  <button type="submit" style="padding: 0.5rem 1rem; background: #28a745; color: #fff; border: none; border-radius: 5px; cursor: pointer;">Approve</button>
                </form>
                <form method="POST" action="/admin/delete/learn/<%= resource.id %>" style="display: inline;">
                  <button type="submit" style="padding: 0.5rem 1rem; background: #d9534f; color: #fff; border: none; border-radius: 5px; cursor: pointer;" onclick="return confirm('Are you sure you want to delete this resource?');">Delete</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
        </section>

        <!-- Submissions Queue summary -->
        <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem; margin-top: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
          <div>
            <h2 style="color: var(--color-primary); margin: 0 0 0.4rem;">User Submissions</h2>
            <p style="color: #666; margin: 0; font-size: 0.95rem;">New festival, band, camp, venue, and photo submissions pending review.</p>
          </div>
          <a href="/admin/submissions?filter=submissions" style="display: inline-block; background: #225675; color: #fff; font-weight: 700; border-radius: 8px; padding: 0.75rem 1.5rem; font-size: 0.95rem; text-decoration: none; white-space: nowrap;">
            View All (<%= stats.pendingSubmissions %> pending)
          </a>
        </section>

        <!-- Reports Queue summary -->
        <section style="background: #fff; border-radius: 10px; box-shadow: 0 2px 8px rgba(34,86,117,0.06); padding: 2rem; margin-top: 1rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
          <div>
            <h2 style="color: #b94040; margin: 0 0 0.4rem;">Reports of Errors</h2>
            <p style="color: #666; margin: 0; font-size: 0.95rem;">Listing problems reported by public users across concerts, festivals, venues, and jams.</p>
          </div>
          <a href="/admin/submissions?filter=reports" style="display: inline-block; background: #b94040; color: #fff; font-weight: 700; border-radius: 8px; padding: 0.75rem 1.5rem; font-size: 0.95rem; text-decoration: none; white-space: nowrap;">
            View All (<%= stats.pendingReports %> pending)
          </a>
        </section>

      </div>
    </div>
  </main>
</body>
</html>

