<% /* Band Profile Detail Page */ %>
<% layout('layout') %>

<article class="boldwp-post-singular boldwp-box detail-page-card" style="max-width:900px;margin:2.5rem auto 0 auto;width:100%;">
  <div class="boldwp-box-inside">
    <header class="entry-header" style="text-align:center;">
      <div class="entry-header-inside">
        <h1 class="entry-title" style="font-size:2.5rem;margin:0.5rem 0;"><%= band.BandName %></h1>
      </div>
    </header>

    <div class="entry-content" style="text-align:center;">
      <div style="display:flex;justify-content:center;align-items:center;margin:1.5rem 0;">
        <img src="<%= imageUrl %>" alt="<%= band.BandName %>" onerror="this.onerror=null;this.src='https://images.lesterslist.com/media/lesterlogo_sq.png';" style="width:100%;max-width:420px;height:260px;object-fit:cover;object-position:<%= typeof imageAlignment !== 'undefined' ? imageAlignment : 'top' %>;border-radius:12px;box-shadow:0 2px 12px rgba(34,86,117,0.08);background:#fff;" loading="lazy">
      </div>

      <!-- Collapsible Map Container -->
      <div class="map-accordion" style="margin: 2rem 0; border: 1px solid #e0e6ed; border-radius: 12px; overflow: hidden; background: #fff; box-shadow: 0 4px 15px rgba(34,86,117,0.05);">
        <button onclick="toggleMap()" style="width: 100%; padding: 0.85rem 1.25rem; display: flex; align-items: center; border: none; background: #f8fafc; cursor: pointer; transition: background 0.2s; outline: none;">
          <span id="map-chevron" style="font-size: 0.8rem; color: #94a3b8; transition: transform 0.3s ease; transform: rotate(180deg); margin-right: 1rem;">▼</span>
          <span style="font-weight: 700; color: var(--color-secondary-blue); font-size: 1.1rem; display: flex; align-items: center; gap: 0.6rem; padding-left: 0.5rem;">
            🗺️ Tour Locations Map
          </span>
        </button>
        <div id="map-content" style="max-height: 500px; transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1); overflow: hidden;">
          <div id="bandMap" style="height:400px; width: 100%;"></div>
        </div>
      </div>

      <% if (band.BandWebsite && band.BandWebsite.trim()) { %>
        <%
          const bandWebsiteRaw = band.BandWebsite.trim();
          const normalizedBandUrl = bandWebsiteRaw.startsWith('http') ? bandWebsiteRaw : 'https://' + bandWebsiteRaw;
          
          // Clean up the band name for the button: 
          // Use the exact BandName property from the database
          const buttonName = band.BandName || 'Band';
          const bandWebsiteButtonText = `🎵 Visit ${buttonName} Website`;
        %>
        <div style="margin-top: 2rem; padding: 1.5rem; background: #fdfdfd; border-radius: 12px; border: 1px dashed #ced4da; display: inline-block; max-width: 600px;">
          <p style="color: #666; font-size: 0.95rem; margin-bottom: 1.25rem; line-height: 1.5; font-style: italic;">
            Find more information about the artists, tickets, schedule changes, showtimes, and more at the band website.
          </p>
          <a href="<%= normalizedBandUrl %>" target="_blank" rel="noopener" style="display:inline-block;padding:0.85rem 1.75rem;background:#3D8C95;color:#fff;font-weight:700;border-radius:8px;text-decoration:none;font-size:1.05rem;transition:all 0.2s;box-shadow: 0 4px 6px rgba(61, 140, 149, 0.2);" onmouseover="this.style.opacity='0.9';this.style.transform='translateY(-1px)'" onmouseout="this.style.opacity='1';this.style.transform='translateY(0)'">
            <%= bandWebsiteButtonText %>
          </a>
        </div>
      <% } %>
    </div>
  </div>
</article>

<section class="boldwp-box detail-page-section" style="max-width:900px;margin:2rem auto 0 auto;width:100%;">
  <div class="boldwp-box-inside">
    <h2 style="color:var(--color-secondary);margin-bottom:1rem;font-size:1.3rem;">Upcoming Appearances</h2>
    <% if (concerts.length === 0) { %>
      <div style="color:#888;font-size:0.9rem;">No appearances listed yet.</div>
    <% } else { %>
      <div style="display:flex;flex-direction:column;gap:4px;">
        <% concerts.forEach(concert => { %>
          <a href="/concerts/<%= concert.ConcertNumber %>" 
             style="display:flex;align-items:center;justify-content:space-between;padding:0.6rem 1rem;background:#fcfcfc;border:1px solid #f0f0f0;border-radius:6px;text-decoration:none;transition:background 0.1s ease;gap:1.5rem;"
             onmouseover="this.style.background='#f3f7f9';this.style.borderColor='#e2e8f0'"
             onmouseout="this.style.background='#fcfcfc';this.style.borderColor='#f0f0f0'">
            <div style="display:flex;align-items:center;gap:1rem;flex:1;min-width:0;">
              <span style="font-weight:700;color:var(--color-secondary-blue);font-size:0.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;">
                <%= concert.ConcertName %>
              </span>
              <span style="color:#666;font-size:0.85rem;white-space:nowrap;flex-shrink:0;">
                <% if (concert.City || concert.State) { %>
                  📍 <%= [concert.City, concert.State].filter(Boolean).join(', ') %>
                <% } %>
              </span>
            </div>
            <div style="font-weight:600;color:var(--color-primary-teal);font-size:0.85rem;white-space:nowrap;flex-shrink:0;">
              <%= new Date(concert.ConcertDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<!-- Report a Problem -->
<div class="report-problem" style="max-width:900px;margin:0 auto 4rem auto;padding:1.5rem 0;">
  <a href="/report?type=band&id=<%= band.BandNumber %>">
    🚩 Report a problem with any information on this page
  </a>
</div>

<script>
  let mapInstance = null;

  function toggleMap() {
    const content = document.getElementById('map-content');
    const chevron = document.getElementById('map-chevron');
    const mapDiv = document.getElementById('bandMap');

    if (content.style.maxHeight !== '0px') {
      content.style.maxHeight = '0px';
      chevron.style.transform = 'rotate(0deg)';
    } else {
      content.style.maxHeight = '500px';
      chevron.style.transform = 'rotate(180deg)';
      // Trigger a resize if the map was loaded while hidden
      if (mapInstance) {
        setTimeout(() => {
          google.maps.event.trigger(mapInstance, 'resize');
          // Optional: re-center or re-fit if needed
        }, 100);
      }
    }
  }

  function initBandMap() {
    const markers = <%- JSON.stringify(mapData) %>;
    const mapDiv = document.getElementById('bandMap');

    const map = new google.maps.Map(mapDiv, {
      center: { lat: 39.8283, lng: -98.5795 }, // Default: US center
      zoom: 4,
      mapTypeId: 'roadmap'
    });
    
    mapInstance = map;

    if (markers.length === 0) return;

    const bounds = new google.maps.LatLngBounds();
    let pinCount = 0;

    markers.forEach(marker => {
      const lat = parseFloat(marker.Latitude);
      const lng = parseFloat(marker.Longitude);
      if (!lat || !lng || isNaN(lat) || isNaN(lng)) return;

      pinCount++;

      const dateStr = marker.date
        ? new Date(marker.date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' })
        : 'Date TBD';

      const m = new google.maps.Marker({
        position: { lat, lng },
        map,
        title: marker.VenueName
      });

      const info = new google.maps.InfoWindow({
        content: `<div style="padding:6px;max-width:260px;word-break:keep-all;">
          <strong style="font-size:14px;display:block;margin-bottom:4px;">${marker.eventTitle || marker.VenueName}</strong>
          <span style="color:#555;font-size:13px;">📍 ${marker.VenueName}</span><br>
          <span style="color:#555;font-size:13px;">📅 ${dateStr}</span>
        </div>`
      });

      m.addListener('click', () => info.open(map, m));
      bounds.extend({ lat, lng });
    });

    if (pinCount > 0) {
      map.fitBounds(bounds);
      const listener = google.maps.event.addListener(map, 'idle', () => {
        if (map.getZoom() > 12) map.setZoom(12);
        google.maps.event.removeListener(listener);
      });
    }

    console.log(`Band map loaded with ${pinCount} pins.`);
  }
</script>
<script src="https://maps.googleapis.com/maps/api/js?key=<%= GOOGLE_MAPS_API_KEY %>&callback=initBandMap" async defer></script>
