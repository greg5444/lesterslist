<% /* Concert Detail Page - BoldWP Structure */ %>
<% layout('layout') %>

<article class="boldwp-post-singular boldwp-box detail-page-card" style="max-width:1100px;margin:2.5rem auto 0 auto;width:100%;">
  <div class="boldwp-box-inside">
    <header class="entry-header">
      <div class="entry-header-inside">
        <h1 class="entry-title" style="font-size:2.1rem;margin:0.5rem 0;color:var(--color-secondary-blue);"><%= concert.ConcertName %></h1>
      </div>
    </header>
    
    <div class="entry-content" style="display:flex;flex-wrap:wrap;gap:2.5rem;margin-top:1.5rem;">
      <!-- Left: Poster with Date Badge -->
      <div style="flex:1 1 420px;min-width:280px;display:flex;align-items:flex-start;justify-content:center;">
        <div style="position:relative;width:100%;max-width:453px;">
          <img src="<%= displayImage %>" alt="Concert Poster" onerror="this.onerror=null;this.src='https://images.lesterslist.com/media/All-bluegrass.jpg';" style="width:100%;height:340px;object-fit:cover;border-radius:10px;background:#f8f9fa;box-shadow:0 2px 8px rgba(34,86,117,0.06);">
          <!-- Date Badge Overlay (ORANGE) -->
          <div class="date-badge">
            <div class="date-month"><%= concertMonth %></div>
            <div class="date-day"><%= concertDay %></div>
          </div>
        </div>
      </div>
      
      <!-- Right: Info -->
      <div style="flex:2 1 400px;min-width:260px;">
        <!-- Concert Date -->
        <div style="margin-bottom:1.2rem;font-size:1.3rem;color:#225675;font-weight:600;">
          <%= new Date(concert.ConcertDate).toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric', year:'numeric' }) %>
        </div>

        <!-- Venue Name -->
        <% if (concert.Venue && concert.Venue.VenueName) { %>
          <div style="margin-bottom:1.2rem;">
            <h3 class="venue-name" style="margin:0 0 0.3rem 0;"><%= concert.Venue.VenueName %></h3>
            <div style="color:#225675;font-size:1rem;">
              <% if (concert.Venue.VenueStreetAddress) { %><%= concert.Venue.VenueStreetAddress %><br><% } %>
              <%= concert.Venue.City %>, <%= concert.Venue.State %> <%= concert.Venue.Zip || '' %>
            </div>
          </div>
        <% } %>

        <!-- Band Info -->
        <% if (concert.Band && concert.Band.BandName) { %>
          <div style="margin-bottom:1.2rem;font-size:1rem;color:#225675;">
            Featuring:
            <a href="/bands/<%= concert.Band.BandNumber %>" style="color:var(--color-highlight-orange);font-weight:700;text-decoration:underline;margin-left:0.25rem;"><%= concert.Band.BandName %></a>
          </div>
        <% } %>

        <!-- Festival Banner -->
        <% 
          const isStandAlone = concert.Festival && (concert.Festival.FestivalNumber === 'F00001' || (concert.ConcertName && concert.ConcertName.includes('In Concert')));
          if (concert.Festival && concert.Festival.FestivalName && !isStandAlone) { 
        %>
          <div style="margin-bottom:1.2rem;border-left:4px solid var(--color-primary-teal);padding:0.6rem 1rem;">
            <div style="font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--color-primary-teal);margin-bottom:0.2rem;">Part of Festival</div>
            <a href="/festivals/<%= concert.Festival.FestivalNumber %>" style="color:#225675;font-weight:700;font-size:1rem;text-decoration:none;">
              <%= concert.Festival.FestivalName %> →
            </a>
          </div>
        <% } %>

        <!-- Action Buttons -->
        <div style="margin-top:1.5rem;display:flex;gap:1rem;flex-wrap:wrap;">
          <% if (concert.Band && concert.Band.BandWebsite) { %>
            <% 
              const concertBandWebsiteRaw = concert.Band.BandWebsite.trim();
              const concertBandWebsiteUrl = concertBandWebsiteRaw.startsWith('http') ? concertBandWebsiteRaw : 'https://' + concertBandWebsiteRaw;
              const concertBandWebsiteDisplay = concertBandWebsiteRaw.replace(/^https?:\/\//i, '').replace(/\/+$/, '');
              const concertBandWebsiteText = concertBandWebsiteDisplay.length <= 38
                ? `🎸 Visit ${concertBandWebsiteDisplay} website`
                : '🎸 Visit Band Website';
            %>
            <a href="<%= concertBandWebsiteUrl %>" target="_blank" rel="noopener" style="display:inline-block;background:var(--color-highlight-orange);color:#fff;font-weight:700;border-radius:8px;padding:0.8rem 1.8rem;font-size:1rem;transition:opacity 0.2s;text-shadow:0 1px 2px rgba(0,0,0,0.2);" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
              <%= concertBandWebsiteText %>
            </a>
          <% } %>
          <% 
            const isStandAloneForButton = concert.Festival && (concert.Festival.FestivalNumber === 'F00001' || (concert.ConcertName && concert.ConcertName.includes('In Concert')));
            if (concert.Festival && concert.Festival.FestivalNumber && !isStandAloneForButton) { 
          %>
            <a href="/festivals/<%= concert.Festival.FestivalNumber %>" style="display:inline-flex;align-items:center;gap:0.6rem;background:var(--color-primary-teal);color:#fff;font-weight:700;border-radius:8px;padding:0.8rem 1.25rem;font-size:1rem;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
              <img src="https://images.lesterslist.com/media/lesterlogo_sq.png" alt="LestersList" style="width:40px;height:40px;border-radius:999px;object-fit:cover;border:1px solid rgba(255,255,255,0.75);background:#fff;">
              <span>View Full Festival</span>
            </a>
          <% } %>
        </div>

        <!-- Extra Detail (below buttons) -->
        <% if (concert.ExtraDetail) { %>
          <div style="margin-top:1.5rem;font-size:1rem;color:#225675;line-height:1.7;">
            <%= concert.ExtraDetail %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</article>

<!-- Location Section -->
<section class="boldwp-box detail-page-section" style="max-width:1100px;margin:2rem auto 0 auto;width:100%;">
  <div class="boldwp-box-inside">
    <% if (concert.GoogleMapAddress && googleMapsApiKey) { %>
      <div style="display:flex;flex-wrap:wrap;gap:2rem;align-items:flex-start;">
        <div style="flex:2 1 340px;min-width:260px;">
          <iframe
            width="100%"
            height="260"
            style="max-width:500px;border:0;border-radius:10px;box-shadow:0 2px 12px rgba(34,86,117,0.08);"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps/embed/v1/place?key=<%= googleMapsApiKey %>&q=<%= encodeURIComponent(concert.GoogleMapAddress) %>">
          </iframe>
        </div>
        <div style="flex:1 1 220px;min-width:180px;color:#225675;font-size:1rem;">
          <% if (concert.Venue && concert.Venue.VenueName) { %>
            <div style="font-weight:700;margin-bottom:0.4rem;"><%= concert.Venue.VenueName %></div>
          <% } %>
          <div><%= concert.VenueStreetAddress %></div>
          <div><%= concert.City %>, <%= concert.State %> <%= concert.Zip %></div>
        </div>
        <% if (concert.GoogleMapAddress) { %>
          <div style="margin-top:1.2rem;">
            <a href="https://www.google.com/maps/dir/?api=1&destination=<%= encodeURIComponent(concert.GoogleMapAddress) %>" target="_blank" style="color:var(--color-primary-teal);font-weight:700;text-decoration:none;font-size:1rem;">
              🚗 Get Driving Directions
            </a>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</section>

<!-- Report a Problem -->
<div style="max-width:1100px;margin:0.5rem auto 1.5rem auto;padding:0 1rem;">
  <a href="/report?type=concert&id=<%= concert.ConcertNumber %>" style="color:#bbb;font-size:0.82rem;text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;">
    🚩 Report a problem with any information on this page
  </a>
</div>
