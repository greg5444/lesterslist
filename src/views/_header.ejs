<!-- Row 1: Top Bar (Teal background, White text) -->
<div class="boldwp-top-bar" style="background:#3D8C95;color:#fff;padding:0.5rem 1.5rem;font-size:0.85rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid #2d7179;">
  <div class="ticker-section">
    <span style="font-weight:600;">🎵 Find Bluegrass Near You</span>
  </div>
  <div class="date-section" style="font-weight:500;">
    <%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
  </div>
</div>

<!-- Row 2: Branding Bar (White background) -->
<div class="boldwp-branding-bar" style="background:#fff;padding:2rem 1.5rem;border-bottom:1px solid #eee;">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:2rem;">
    <div class="logo-section" style="flex-shrink:0;">
      <a href="/">
        <img src="https://images.lesterslist.com/media/lesterlogo-trans-01.png" alt="Lesterslist Logo" style="max-height:140px;display:block;">
      </a>
    </div>
    
    <!-- Center Section: Title and Search -->
    <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:1rem;">
      <h1 style="color:#3D8C95;font-size:5rem;font-weight:900;margin:0;font-family:var(--font-serif);letter-spacing:0.15rem;">Lester's List</h1>
      
      <!-- Search Form -->
      <div class="search-section" style="width:100%;max-width:780px;">
        <form action="/search" method="GET" style="width:100%;">
          <div style="position:relative;">
            <input type="text" name="q" placeholder="Search bands, concerts, festivals, jams, venues..." style="width:100%;padding:0.8rem 3rem 0.8rem 1rem;border:2px solid #ddd;border-radius:8px;font-size:0.95rem;font-family:var(--font-sans);transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--color-primary-teal)'" onblur="this.style.borderColor='#ddd'">
            <button type="submit" style="position:absolute;right:0.5rem;top:50%;transform:translateY(-50%);background:var(--color-primary-teal);color:#fff;border:none;padding:0.5rem 1rem;border-radius:6px;cursor:pointer;font-weight:600;font-size:0.9rem;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
              🔍
            </button>
          </div>
        </form>
      </div>
    </div>
    
    <div class="ad-section" style="background:linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);padding:1rem 2rem;border-radius:6px;border:2px dashed #ccc;flex-shrink:0;white-space:nowrap;text-align:center;min-width:200px;">
      <div style="font-size:0.75rem;color:#999;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.3rem;">Advertisement</div>
      <div style="font-size:0.9rem;color:#666;font-weight:600;">Your Ad Here</div>
      <div style="font-size:0.75rem;color:#888;margin-top:0.2rem;">728 x 90</div>
    </div>
  </div>
</div>

<!-- Row 3: Navigation Bar (Deep Blue background, White links) -->
<nav class="boldwp-nav-bar" style="background:#225675;padding:0;border-bottom:2px solid #1a3f54;">
  <div class="hamburger" aria-label="Open navigation" tabindex="0" style="display:none;padding:1rem;cursor:pointer;">
    <span style="display:block;width:28px;height:3px;background:#fff;margin:5px 0;border-radius:2px;"></span>
    <span style="display:block;width:28px;height:3px;background:#fff;margin:5px 0;border-radius:2px;"></span>
    <span style="display:block;width:28px;height:3px;background:#fff;margin:5px 0;border-radius:2px;"></span>
  </div>
  <div class="nav-links" style="display:flex;justify-content:center;align-items:center;gap:0;">
    <a href="/concerts" style="color:#fff;text-decoration:none;padding:1rem 1.5rem;font-weight:600;font-size:0.9rem;letter-spacing:0.3px;text-transform:uppercase;transition:background 0.2s;display:inline-block;">Concerts</a>
    <a href="/festivals" style="color:#fff;text-decoration:none;padding:1rem 1.5rem;font-weight:600;font-size:0.9rem;letter-spacing:0.3px;text-transform:uppercase;transition:background 0.2s;display:inline-block;">Festivals</a>
    <a href="/bands" style="color:#fff;text-decoration:none;padding:1rem 1.5rem;font-weight:600;font-size:0.9rem;letter-spacing:0.3px;text-transform:uppercase;transition:background 0.2s;display:inline-block;">Bands</a>
    <a href="/camps" style="color:#fff;text-decoration:none;padding:1rem 1.5rem;font-weight:600;font-size:0.9rem;letter-spacing:0.3px;text-transform:uppercase;transition:background 0.2s;display:inline-block;">Camps/Workshops</a>
    <a href="/jams" style="color:#fff;text-decoration:none;padding:1rem 1.5rem;font-weight:600;font-size:0.9rem;letter-spacing:0.3px;text-transform:uppercase;transition:background 0.2s;display:inline-block;">Local Jams &ndash;<wbr> Find Your Circle</a>
    <a href="/map" style="color:#fff;text-decoration:none;padding:1rem 1.5rem;font-weight:600;font-size:0.9rem;letter-spacing:0.3px;text-transform:uppercase;transition:background 0.2s;display:inline-block;">Events on Map</a>
  </div>
</nav>

