<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Lesterslist' %></title>
  <link rel="icon" href="https://images.lesterslist.com/media/lesterlogo_sq.png" type="image/png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <!-- Load fonts non-render-blocking: media=print trick then swap to all -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Playfair+Display:wght@400;600;700&display=swap" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Playfair+Display:wght@400;600;700&display=swap"></noscript>
</head>
<body>
  <% if (isAdmin) { %>
  <div style="position:fixed;top:0;left:0;right:0;z-index:99999;background:#1a3a50;color:#fff;display:flex;align-items:center;gap:1rem;padding:0 1rem;height:36px;font-size:0.82rem;font-family:sans-serif;box-shadow:0 2px 6px rgba(0,0,0,0.4);">
    <a href="/admin/dashboard" style="color:#3ec9d6;font-weight:700;text-decoration:none;white-space:nowrap;">⚙️ Admin</a>
    <span style="color:#555;">|</span>
    <a href="/bands" style="color:#ccc;text-decoration:none;">Bands</a>
    <a href="/concerts" style="color:#ccc;text-decoration:none;">Concerts</a>
    <a href="/festivals" style="color:#ccc;text-decoration:none;">Festivals</a>
    <a href="/jams" style="color:#ccc;text-decoration:none;">Jams</a>
    <a href="/camps" style="color:#ccc;text-decoration:none;">Camps</a>
    <span style="flex:1;"></span>
    <% const path = locals.currentPath || ''; %>
    <% const idMatch = path.match(/\/(bands|festivals|concerts)\/([A-Za-z0-9]+)/); %>
    <% if (idMatch) { %>
      <a href="/admin/edit/<%= idMatch[1].replace(/s$/, '') %>/<%= idMatch[2] %>" style="background:#e6873c;color:#fff;padding:0.2rem 0.75rem;border-radius:4px;text-decoration:none;font-weight:700;">✏️ Edit This <%= idMatch[1].replace(/s$/, '') %></a>
    <% } %>
    <a href="/admin/logout" style="color:#f88;text-decoration:none;margin-left:0.5rem;">Logout</a>
  </div>
  <div style="height:36px;"></div>
  <% } %>
  <!-- Coming Soon Curtain Overlay with Password Unlock -->
  <div id="curtain-overlay" style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(34,86,117,0.97);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;font-family:'Inter',sans-serif;text-align:center;">
    <img src="https://images.lesterslist.com/media/lesterlogo_sq.png" alt="Lesterslist Logo" style="width:120px;height:120px;margin-bottom:2rem;filter:drop-shadow(0 2px 8px #000);">
    <h1 style="font-size:2.5rem;font-weight:700;margin-bottom:1rem;">Coming Soon</h1>
    <p style="font-size:1.3rem;margin-bottom:2.5rem;max-width:480px;">We're working hard to launch the new Lesterslist directory. Please check back soon!</p>
    <form id="curtain-form" style="margin-bottom:2rem;">
      <input type="password" id="curtain-password" placeholder="Enter access code" style="padding:1rem;font-size:1.2rem;border-radius:8px;border:none;outline:none;width:220px;text-align:center;margin-bottom:1rem;">
      <button type="submit" style="padding:0.8rem 2rem;font-size:1.1rem;border-radius:8px;background:#ff9800;color:#fff;font-weight:700;border:none;cursor:pointer;">Unlock</button>
      <div id="curtain-error" style="color:#ffbdbd;font-size:1rem;margin-top:0.5rem;display:none;">Incorrect code. Please try again.</div>
    </form>
    <div style="font-size:1rem;opacity:0.7;">For questions, email <a href="mailto:info@lesterslist.com" style="color:#fff;text-decoration:underline;">info@lesterslist.com</a></div>
  </div>
  <div class="boldwp-site-wrapper">
    <div class="boldwp-container">
      <%- include('_header') %>
      <main>
        <%- body %>
      </main>
      <%- include('_footer') %>
    </div>
  </div>
  <script src="/js/main.js"></script>
  <script>
    // Curtain unlock logic
    const curtainOverlay = document.getElementById('curtain-overlay');
    const curtainForm = document.getElementById('curtain-form');
    const curtainPassword = document.getElementById('curtain-password');
    const curtainError = document.getElementById('curtain-error');
    if (curtainForm) {
      curtainForm.addEventListener('submit', function(e) {
        e.preventDefault();
        if (curtainPassword.value === 'lester747') {
          curtainOverlay.style.display = 'none';
          localStorage.setItem('curtainUnlocked', 'true');
        } else {
          curtainError.style.display = 'block';
        }
      });
      // Hide curtain if previously unlocked
      if (localStorage.getItem('curtainUnlocked') === 'true') {
        curtainOverlay.style.display = 'none';
      }
    }
  </script>
</body>
</html>

