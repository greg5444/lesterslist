<% /* Camp/Workshop Detail Page - BoldWP Structure */ %>
<% layout('layout') %>
<%
  // Calculate event duration in days for the badge overlay
  let durationNum = '';
  let durationWord = '';
  if (camp.StartDate && camp.EndDate) {
    const start = new Date(camp.StartDate);
    const end = new Date(camp.EndDate);
    const diff = Math.round((end - start) / (1000 * 60 * 60 * 24)) + 1;
    if (!isNaN(diff) && diff > 0) {
      durationNum = diff;
      durationWord = diff === 1 ? 'day' : 'days';
    }
  }
%>

<article class="boldwp-post-singular boldwp-box detail-page-card" style="max-width:1100px;margin:2.5rem auto 0 auto;width:100%;">
  <div class="boldwp-box-inside">
    <header class="entry-header">
      <div class="entry-header-inside">
        <h1 class="entry-title" style="font-size:2.1rem;margin:0.5rem 0;color:var(--color-secondary-blue);"><%= camp.EventName %></h1>
      </div>
    </header>
    
    <div class="entry-content" style="display:flex;flex-wrap:wrap;gap:2.5rem;margin-top:1.5rem;">
      <!-- Left: Poster with Orange Overlay for Duration -->
      <div style="flex:1 1 320px;min-width:280px;display:flex;align-items:flex-start;justify-content:center;">
        <div style="position:relative;width:100%;max-width:340px;">
          <img src="<%= imageUrl %>" alt="Camp/Workshop Image" onerror="this.onerror=null;this.src='https://images.lesterslist.com/media/All-bluegrass.jpg';" style="width:100%;height:340px;object-fit:cover;border-radius:10px;background:#f8f9fa;box-shadow:0 2px 8px rgba(34,86,117,0.06);">
          <% if (durationNum && durationWord) { %>
            <div class="date-badge" style="position:absolute;bottom:15px;left:15px;min-width:75px;display:flex;flex-direction:column;align-items:center;justify-content:center;">
              <span style="font-size:1.8rem;font-weight:800;letter-spacing:1.5px;line-height:1.1;text-transform:uppercase;text-shadow:1px 1px 2px rgba(0,0,0,0.3);font-family:var(--font-display);margin-bottom:3px;">
                <%= durationNum %>
              </span>
              <span style="font-size:1.1rem;font-weight:700;line-height:1.1;text-transform:uppercase;text-shadow:1px 1px 2px rgba(0,0,0,0.3);font-family:var(--font-display);">
                <%= durationWord %>
              </span>
            </div>
          <% } %>
        </div>
      </div>
      
      <!-- Right: Info -->
      <div style="flex:2 1 400px;min-width:260px;">

        <!-- Admin Edit -->
        <% if (isAdmin) { %>
          <div style="margin-bottom:1rem;">
            <a href="/admin/edit/camp/<%= camp.JDNumber %>" style="display:inline-block;background:rgba(34,86,117,0.88);color:#fff;border-radius:6px;padding:0.35rem 0.75rem;font-size:0.82rem;text-decoration:none;font-weight:700;">✏️ Edit in Admin</a>
          </div>
        <% } %>

        <!-- Extra Detail -->
        <% if (camp.ExtraDetail) { %>
          <div style="margin-bottom:1.2rem;font-size:1rem;color:#225675;line-height:1.7;">
            <%= camp.ExtraDetail %>
          </div>
        <% } %>

        <!-- Date Range -->
        <% if (camp.DateRange) { %>
          <div style="margin-bottom:1.2rem;font-size:1.3rem;color:#225675;font-weight:600;">
            <%= camp.DateRange %>
          </div>
        <% } %>

        <!-- Venue Name + Address -->
        <div style="margin-bottom:1.2rem;">
          <% if (camp.VenueName && camp.VenueName.trim()) { %>
            <h3 class="venue-name" style="margin:0 0 0.3rem 0;"><%= camp.VenueName %></h3>
          <% } %>
          <div style="color:#225675;font-size:1rem;">
            <% if (camp.Street && camp.Street.trim()) { %><%= camp.Street %><br><% } %>
            <%= camp.City || '' %><% if (camp.City && camp.State) { %>, <% } %><%= camp.State ? camp.State.trim() : '' %> <%= camp.Zip || '' %>
          </div>
        </div>

        <!-- Contact Info -->
        <% if (camp.Contact) { %>
          <div style="margin-bottom:1.2rem;font-size:1rem;color:#225675;">
            Contact: <span style="font-weight:600;"><%= camp.Contact %></span>
          </div>
        <% } %>

        <!-- Action Buttons -->
        <div style="margin-top:1.5rem;display:flex;gap:1rem;flex-wrap:wrap;">
          <% if (camp.ExternalURL) { %>
            <%
              const campWebsiteRaw = camp.ExternalURL.trim();
              const campWebsiteUrl = campWebsiteRaw.startsWith('http') ? campWebsiteRaw : 'https://' + campWebsiteRaw;
              const campWebsiteDisplay = campWebsiteRaw.replace(/^https?:\/\//i, '').replace(/\/+$/, '');
              const campWebsiteText = campWebsiteDisplay.length <= 38
                ? `🎵 Visit ${campWebsiteDisplay} website`
                : '🎵 Visit Website';
            %>
            <a href="<%= campWebsiteUrl %>" target="_blank" rel="noopener" style="display:inline-block;background:var(--color-highlight-orange);color:#fff;font-weight:700;border-radius:8px;padding:0.8rem 1.8rem;font-size:1rem;transition:opacity 0.2s;text-shadow:0 1px 2px rgba(0,0,0,0.2);text-decoration:none;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
              <%= campWebsiteText %>
            </a>
          <% } %>
          <% if (camp.Contact && camp.Contact.includes('@')) { %>
            <a href="mailto:<%= camp.Contact %>" style="display:inline-block;background:var(--color-primary-teal);color:#fff;font-weight:700;border-radius:8px;padding:0.8rem 1.8rem;font-size:1rem;transition:opacity 0.2s;text-decoration:none;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
              ✉️ Email Organizer
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</article>

<!-- Location Section -->
<% if (mapAddress && googleMapsApiKey) { %>
<section class="boldwp-box detail-page-section" style="max-width:1100px;margin:2rem auto 0 auto;width:100%;">
  <div class="boldwp-box-inside">
    <div style="display:flex;flex-wrap:wrap;gap:2rem;align-items:flex-start;">
      <div style="flex:2 1 340px;min-width:260px;">
        <iframe
          width="100%"
          height="260"
          style="border:0;border-radius:10px;box-shadow:0 2px 12px rgba(34,86,117,0.08);"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed/v1/place?key=<%= googleMapsApiKey %>&q=<%= encodeURIComponent(mapAddress) %>">
        </iframe>
      </div>
      <div style="flex:1 1 220px;min-width:180px;color:#225675;font-size:1rem;">
        <% if (camp.VenueName && camp.VenueName.trim()) { %>
          <div style="font-weight:700;margin-bottom:0.4rem;"><%= camp.VenueName %></div>
        <% } %>
        <% if (camp.Street && camp.Street.trim()) { %>
          <div><%= camp.Street %></div>
        <% } %>
        <div><%= camp.City || '' %><% if (camp.City && camp.State) { %>, <% } %><%= camp.State ? camp.State.trim() : '' %> <%= camp.Zip || '' %></div>
      </div>
    </div>
  </div>
</section>
<% } %>

<!-- Report a Problem -->
<div style="max-width:1100px;margin:0.5rem auto 1.5rem auto;padding:0 1rem;">
  <a href="/report?type=camp&id=<%= camp.JDNumber %>" style="color:#bbb;font-size:0.82rem;text-decoration:none;display:inline-flex;align-items:center;gap:0.4rem;">
    🚩 Report a problem with any information on this page
  </a>
</div>
