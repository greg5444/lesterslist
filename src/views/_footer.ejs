<footer style="background: var(--color-secondary-blue); color: #fff; margin-top: 4rem;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem;">
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
      <!-- Left Column: About -->
      <div>
        <h3 style="font-size: 1.1rem; margin: 0 0 1rem; font-family: var(--font-display);">About Lesterslist</h3>
        <p style="font-size: 0.9rem; line-height: 1.6; margin: 0 0 1rem; color: #e0e8f0;">
          Lesterslist is your comprehensive directory for bluegrass music events, festivals, bands, jam sessions, and educational resources across North America.
        </p>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.9rem;">
          <li><a href="/concerts" style="color: #7fc9d9; text-decoration: none;">Concerts</a></li>
          <li><a href="/festivals" style="color: #7fc9d9; text-decoration: none;">Festivals</a></li>
          <li><a href="/camps" style="color: #7fc9d9; text-decoration: none;">Camps & Workshops</a></li>
          <li><a href="/jams" style="color: #7fc9d9; text-decoration: none;">Local Jams</a></li>
          <li><a href="/learn" style="color: #7fc9d9; text-decoration: none;">Learning Resources</a></li>
        </ul>
      </div>

      <!-- Center Column: Submit Button -->
      <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
        <div style="margin-bottom: 1.5rem;">
          <p style="font-size: 0.9rem; color: #d0d8e0; margin: 0 0 0.75rem;">Have something to share?</p>
          <a href="/submit" style="display: inline-block; background: var(--color-highlight-orange); color: #fff; padding: 0.85rem 2rem; border-radius: 6px; font-weight: 700; text-decoration: none; transition: opacity 0.2s; font-size: 1rem;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
            Submit a Resource
          </a>
        </div>
        <p style="font-size: 0.75rem; color: #98b0c4; margin: 0;">Add festivals, bands, venues, or news to the directory.</p>
      </div>

      <!-- Right Column: Logo -->
      <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
        <a href="/" style="display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; text-decoration: none;">
          <img src="https://images.lesterslist.com/media/lesterlogo_sq.png"
               alt="Lesterslist"
               style="width: 80px; height: 80px; border-radius: 50%; background: rgba(255,255,255,0.1); padding: 8px; transition: transform 0.2s;"
               onmouseover="this.style.transform='scale(1.05)'"
               onmouseout="this.style.transform='scale(1)'">
        </a>
        <p style="font-size: 0.75rem; color: #98b0c4; margin: 0;">Click to return home</p>
      </div>
    </div>

    <!-- Copyright -->
    <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem; text-align: center;">
      <p style="font-size: 0.8rem; color: #98b0c4; margin: 0;">© 2026 Lesterslist. All Rights Reserved.</p>
    </div>
  </div>

  <!-- Mobile Responsive Adjustment -->
  <style>
    @media (max-width: 768px) {
      footer div:first-child {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
      }
    }
  </style>
</footer>
