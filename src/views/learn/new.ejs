<% layout('layout') %>
<section style="max-width:500px;margin:2.5rem auto 0 auto;">
  <h1 style="color:var(--color-primary-teal);margin-bottom:1.5rem;">Submit a Resource</h1>
  <% if (success) { %>
    <div style="background:var(--color-primary-teal);color:#fff;padding:1rem;border-radius:6px;margin-bottom:1.5rem;">Thanks! Your listing is pending admin approval.</div>
  <% } %>
  <% if (error) { %>
    <div style="background:#dc3545;color:#fff;padding:1rem;border-radius:6px;margin-bottom:1.5rem;"><%= error %></div>
  <% } %>
  <form method="POST" action="/learn/new" style="display:flex;flex-direction:column;gap:1rem;">
    <input type="text" name="InstructorName" placeholder="Instructor Name" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    <input type="text" name="CourseDescription" placeholder="Course Description" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    <input type="url" name="ExternalLink" placeholder="External Link" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    <button type="submit" style="padding:0.7rem;background:var(--color-highlight-orange);color:#fff;font-weight:600;border:none;border-radius:5px;">Submit</button>
  </form>
</section>

