<% layout('layout') %>
<div class="submit-form-wrap">
  <p class="submit-breadcrumb"><a href="/submit">&larr; Submit a Resource</a></p>
  <h1>Submit a Camp / Workshop</h1>

  <% if (success) { %>
    <div class="submit-alert success">Thanks! Your camp submission has been received and is pending review. We'll be in touch.</div>
  <% } %>
  <% if (error) { %>
    <div class="submit-alert error"><%= error %></div>
  <% } %>

  <% if (!success) { %>
  <form method="POST" action="/submit/camp">

    <%# Event Details %>
    <div class="submit-section">
      <h3 class="submit-section-title">Event Details</h3>
      <div class="submit-grid-2">
        <div class="submit-field full-width">
          <label for="EventName">Event Name <span class="req">*</span></label>
          <input type="text" id="EventName" name="EventName"
                 placeholder="e.g. Augusta Heritage Center Bluegrass Week" required
                 value="<%= typeof formData !== 'undefined' && formData.EventName ? formData.EventName : '' %>">
        </div>
        <div class="submit-field">
          <label for="StartDate">Start Date <span class="req">*</span></label>
          <input type="date" id="StartDate" name="StartDate" required
                 value="<%= typeof formData !== 'undefined' && formData.StartDate ? formData.StartDate : '' %>">
        </div>
        <div class="submit-field">
          <label for="EndDate">End Date <span class="req">*</span></label>
          <input type="date" id="EndDate" name="EndDate" required
                 value="<%= typeof formData !== 'undefined' && formData.EndDate ? formData.EndDate : '' %>">
        </div>
        <div class="submit-field full-width">
          <label for="ExternalURL">Registration / Info URL</label>
          <input type="url" id="ExternalURL" name="ExternalURL"
                 placeholder="https://..."
                 value="<%= typeof formData !== 'undefined' && formData.ExternalURL ? formData.ExternalURL : '' %>">
        </div>
      </div>
    </div>

    <%# Location %>
    <div class="submit-section">
      <h3 class="submit-section-title">Location</h3>
      <div class="submit-grid-2">
        <div class="submit-field full-width">
          <label for="VenueName">Venue / Campus Name</label>
          <input type="text" id="VenueName" name="VenueName"
                 placeholder="e.g. Elkins, WV — Davis & Elkins College"
                 value="<%= typeof formData !== 'undefined' && formData.VenueName ? formData.VenueName : '' %>">
        </div>
        <div class="submit-field full-width">
          <label for="Street">Street Address</label>
          <input type="text" id="Street" name="Street"
                 placeholder="Street Address"
                 value="<%= typeof formData !== 'undefined' && formData.Street ? formData.Street : '' %>">
        </div>
        <div class="submit-field">
          <label for="City">City <span class="req">*</span></label>
          <input type="text" id="City" name="City" placeholder="City" required
                 value="<%= typeof formData !== 'undefined' && formData.City ? formData.City : '' %>">
        </div>
        <div class="submit-field">
          <label for="State">State <span class="req">*</span></label>
          <input type="text" id="State" name="State" placeholder="e.g. WV" required
                 value="<%= typeof formData !== 'undefined' && formData.State ? formData.State : '' %>">
        </div>
        <div class="submit-field">
          <label for="Zip">Zip Code</label>
          <input type="text" id="Zip" name="Zip" placeholder="Zip Code"
                 value="<%= typeof formData !== 'undefined' && formData.Zip ? formData.Zip : '' %>">
        </div>
        <div class="submit-field full-width">
          <label for="GoogleMapAddress">Full Address for Google Maps</label>
          <input type="text" id="GoogleMapAddress" name="GoogleMapAddress"
                 placeholder="Street, City, State, Zip"
                 value="<%= typeof formData !== 'undefined' && formData.GoogleMapAddress ? formData.GoogleMapAddress : '' %>">
        </div>
      </div>
    </div>

    <%# Additional Info %>
    <div class="submit-section">
      <h3 class="submit-section-title">Additional Information</h3>
      <div class="submit-field">
        <label for="Notes">Description / Notes</label>
        <textarea id="Notes" name="Notes"
                  placeholder="Describe the camp or workshop — instructors, curriculum, cost, skill level, etc."><%= typeof formData !== 'undefined' && formData.Notes ? formData.Notes : '' %></textarea>
      </div>
    </div>

    <%- include('_contact') %>

    <button type="submit" class="submit-btn">Submit Camp / Workshop</button>
    <p class="submit-note">* Required fields. Your submission will be reviewed before publishing.</p>
  </form>
  <% } %>
</div>
