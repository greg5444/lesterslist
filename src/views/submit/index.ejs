<% layout('layout') %>
<section class="submit-hub">
  <div class="submit-hub-header">
    <h1>Submit a Resource</h1>
    <p>Help grow the bluegrass community by sharing events, artists, venues, and more. All submissions are reviewed by our team before being published.</p>
  </div>
  <div class="submit-hub-grid">
    <a href="/submit/festival" class="submit-hub-card">
      <div class="submit-hub-icon">🎪</div>
      <h2>Festival</h2>
      <p>Submit an upcoming bluegrass or folk festival for our listings.</p>
      <span class="submit-hub-cta">Submit &rarr;</span>
    </a>
    <a href="/submit/band" class="submit-hub-card">
      <div class="submit-hub-icon">🎸</div>
      <h2>Band / Tour Update</h2>
      <p>Add a new band listing or send us upcoming tour dates and shows.</p>
      <span class="submit-hub-cta">Submit &rarr;</span>
    </a>
    <a href="/submit/camp" class="submit-hub-card">
      <div class="submit-hub-icon">🏕</div>
      <h2>Camp / Workshop</h2>
      <p>Share an upcoming music camp, workshop, or instructional event.</p>
      <span class="submit-hub-cta">Submit &rarr;</span>
    </a>
    <a href="/submit/venue" class="submit-hub-card">
      <div class="submit-hub-icon">🏛</div>
      <h2>Venue</h2>
      <p>Submit a venue that regularly hosts live bluegrass or roots music.</p>
      <span class="submit-hub-cta">Submit &rarr;</span>
    </a>
    <a href="/submit/photos" class="submit-hub-card">
      <div class="submit-hub-icon">📸</div>
      <h2>Photos</h2>
      <p>Share photos from festivals, shows, or your band for the directory.</p>
      <span class="submit-hub-cta">Submit &rarr;</span>
    </a>
  </div>
  <div style="text-align:center;margin-top:2rem;padding-top:1.5rem;border-top:1px solid #e8ecef;">
    <p style="color:#888;font-size:0.9rem;margin:0 0 0.5rem;">Found an error in an existing listing?</p>
    <a href="/report" style="color:#b94040;font-weight:600;font-size:0.9rem;text-decoration:none;">&#9873; Report a Problem with a Listing</a>
  </div>
</section>
