<% layout('layout') %>

<div style="max-width:1200px;margin:2rem auto;padding:0 1.5rem;">
  <!-- Header -->
  <header style="margin-bottom:2rem;border-bottom:3px solid var(--color-primary-teal);padding-bottom:1rem;">
    <h1 style="font-family:var(--font-display);font-size:2.5rem;color:var(--color-secondary-blue);margin:0 0 0.5rem 0;">
      🎻 Local Jams
    </h1>
    <p style="color:#666;font-size:1.1rem;margin:0 0 1rem 0;">Find regular bluegrass jam sessions in your area. All skill levels welcome!</p>
    <a href="/jams/new" style="display:inline-block;background:var(--color-highlight-orange);color:#fff;padding:0.75rem 1.5rem;border-radius:6px;text-decoration:none;font-weight:600;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
      + Submit a Jam
    </a>
  </header>

  <% if (jams.length === 0) { %>
    <div style="text-align:center;padding:4rem 1rem;background:#f9f9f9;border-radius:12px;">
      <div style="font-size:4rem;margin-bottom:1rem;">🎻</div>
      <p style="font-size:1.2rem;color:#666;margin:0;">No jams are currently listed.</p>
      <p style="font-size:0.95rem;color:#888;margin-top:0.5rem;">Be the first to submit one!</p>
    </div>
  <% } else { %>
    
    <!-- Table Layout -->
    <div style="background:#fff;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,0.08);overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:var(--color-primary-teal);color:#fff;">
            <th style="padding:1rem;text-align:left;font-weight:600;font-size:0.95rem;">Jam Name</th>
            <th style="padding:1rem;text-align:left;font-weight:600;font-size:0.95rem;">Location</th>
            <th style="padding:1rem;text-align:left;font-weight:600;font-size:0.95rem;">Schedule</th>
            <th style="padding:1rem;text-align:left;font-weight:600;font-size:0.95rem;">Level</th>
            <th style="padding:1rem;text-align:left;font-weight:600;font-size:0.95rem;">Contact</th>
          </tr>
        </thead>
        <tbody>
          <% jams.forEach((jam, index) => { %>
            <tr style="border-bottom:1px solid #eee;background:<%= index % 2 === 0 ? '#fff' : '#f9f9f9' %>;">
              <td style="padding:1rem;">
                <div style="font-weight:600;font-size:1.05rem;color:var(--color-secondary-blue);margin-bottom:0.25rem;">
                  <%= jam.JamName %>
                </div>
                <% if (jam.VenueName) { %>
                  <div style="font-size:0.85rem;color:#666;">@ <%= jam.VenueName %></div>
                <% } %>
              </td>
              <td style="padding:1rem;color:#555;font-size:0.95rem;">
                <% if (jam.City && jam.State) { %>
                  <%= jam.City %>, <%= jam.State %>
                <% } else { %>
                  <span style="color:#999;">—</span>
                <% } %>
              </td>
              <td style="padding:1rem;color:#555;font-size:0.9rem;max-width:250px;">
                <%= jam.Schedule ? jam.Schedule.substring(0, 80) : '—' %><%= jam.Schedule && jam.Schedule.length > 80 ? '...' : '' %>
              </td>
              <td style="padding:1rem;">
                <% if (jam.AllWelcome || jam.BeginnersWelcome || jam.AdvancedOnly) { %>
                  <div style="display:flex;flex-direction:column;gap:0.25rem;">
                    <% if (jam.AllWelcome) { %>
                      <span style="background:#28a745;color:#fff;padding:0.2rem 0.5rem;border-radius:4px;font-size:0.75rem;display:inline-block;white-space:nowrap;">All Welcome</span>
                    <% } %>
                    <% if (jam.BeginnersWelcome) { %>
                      <span style="background:#17a2b8;color:#fff;padding:0.2rem 0.5rem;border-radius:4px;font-size:0.75rem;display:inline-block;white-space:nowrap;">Beginners</span>
                    <% } %>
                    <% if (jam.AdvancedOnly) { %>
                      <span style="background:var(--color-highlight-orange);color:#fff;padding:0.2rem 0.5rem;border-radius:4px;font-size:0.75rem;display:inline-block;white-space:nowrap;">Advanced</span>
                    <% } %>
                  </div>
                <% } else { %>
                  <span style="color:#999;">—</span>
                <% } %>
              </td>
              <td style="padding:1rem;color:#555;font-size:0.9rem;">
                <%= jam.ContactName %>
                <% if (jam.ShowPhone && jam.ContactPhone) { %>
                  <div style="font-size:0.85rem;color:#888;margin-top:0.25rem;"><%= jam.ContactPhone %></div>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

  <% } %>
</div>

