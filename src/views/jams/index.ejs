<% layout('layout') %>

<div style="max-width:1200px;margin:2rem auto;padding:0 1.5rem;">
  <!-- Header -->
  <header style="margin-bottom:2rem;border-bottom:3px solid var(--color-primary-teal);padding-bottom:1rem;">
    <h1 style="font-family:var(--font-display);font-size:2.5rem;color:var(--color-secondary-blue);margin:0 0 0.5rem 0;">
      🎻 Local Jams
    </h1>
    <p style="color:#666;font-size:1.1rem;margin:0 0 1rem 0;">Find regular bluegrass jam sessions in your area. All skill levels welcome!</p>
    <a href="/jams/new" style="display:inline-block;background:var(--color-highlight-orange);color:#fff;padding:0.75rem 1.5rem;border-radius:6px;text-decoration:none;font-weight:600;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
      + Submit a Jam
    </a>
  </header>

    <!-- Card/Grid Layout for Jams -->
    <div class="jam-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.5rem;">
      <% jams.forEach(jam => { %>
        <a href="/jams/<%= jam.JamID %>" class="jam-card" style="display:block;background:#fff;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,0.08);padding:1.2rem 1.2rem 1rem 1.2rem;text-decoration:none;color:inherit;transition:transform 0.18s,box-shadow 0.18s;position:relative;min-height:180px;"
          onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,0.12)';"
          onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 12px rgba(0,0,0,0.08)';">
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.7rem;">
            <div style="background:var(--color-primary-teal);color:#fff;border-radius:8px;padding:0.7rem 1.1rem;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:70px;">
              <div style="font-size:1.1rem;font-weight:700;line-height:1.1;white-space:nowrap;"><%= jam.JamName %></div>
            </div>
            <div style="flex:1;">
              <div style="font-size:0.98rem;color:#666;font-weight:500;">
                <% if (jam.City && jam.State) { %>
                  <%= jam.City %>, <%= jam.State %>
                <% } else { %>
                  <span style="color:#999;">—</span>
                <% } %>
              </div>
              <% if (jam.VenueName) { %>
                <div style="font-size:0.92rem;color:#888;">@ <%= jam.VenueName %></div>
              <% } %>
            </div>
          </div>
          <div style="font-size:0.97rem;color:#444;margin-bottom:0.5rem;">
            <%= jam.Schedule ? jam.Schedule.substring(0, 80) : '—' %><%= jam.Schedule && jam.Schedule.length > 80 ? '...' : '' %>
          </div>
          <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.5rem;">
            <% if (jam.AllWelcome) { %>
              <span style="background:#28a745;color:#fff;padding:0.2rem 0.7rem;border-radius:4px;font-size:0.82rem;font-weight:600;">All Welcome</span>
            <% } %>
            <% if (jam.BeginnersWelcome) { %>
              <span style="background:#007bff;color:#fff;padding:0.2rem 0.7rem;border-radius:4px;font-size:0.82rem;font-weight:600;">Beginners</span>
            <% } %>
            <% if (jam.AdvancedOnly) { %>
              <span style="background:#e53935;color:#fff;padding:0.2rem 0.7rem;border-radius:4px;font-size:0.82rem;font-weight:600;">Advanced Only</span>
            <% } %>
          </div>
          <div style="font-size:0.95rem;color:#666;">
            <% if (jam.ContactName) { %>
              <span style="font-weight:600;color:#333;"><%= jam.ContactName %></span>
              <% if (jam.ContactEmail) { %>
                <span style="color:#888;margin-left:0.5rem;">(<%= jam.ContactEmail %>)</span>
              <% } %>
            <% } else { %>
              <span style="color:#999;">—</span>
            <% } %>
          </div>
        </a>
      <% }) %>

    </div>
</div>
</div>

