<% layout('layout') %>
<section style="max-width:500px;margin:2.5rem auto 0 auto;">
  <h1 style="color:var(--color-primary-teal);margin-bottom:1.5rem;">Submit a Jam</h1>
  <% if (success) { %>
    <div style="background:var(--color-primary-teal);color:#fff;padding:1rem;border-radius:6px;margin-bottom:1.5rem;">Thanks! Your listing is pending admin approval.</div>
  <% } %>
  <% if (error) { %>
    <div style="background:#dc3545;color:#fff;padding:1rem;border-radius:6px;margin-bottom:1.5rem;"><%= error %></div>
  <% } %>
  <form method="POST" action="/jams/new" style="display:flex;flex-direction:column;gap:1rem;">
    <input type="text" name="JamName" placeholder="Jam Name *" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    <input type="text" name="VenueName" placeholder="Venue Name *" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    <textarea name="Schedule" placeholder="Tell us about the jam: When it meets, how often (weekly, monthly), what days/times, what to expect at this jam *" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;min-height:100px;resize:vertical;"></textarea>
    
    <div style="background:#f5f5f5;padding:1rem;border-radius:5px;margin-top:0.5rem;">
      <h3 style="margin:0 0 0.75rem 0;color:#225675;font-size:1rem;">Jam Level (select all that apply)</h3>
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-bottom:0.5rem;">
        <input type="checkbox" name="AllWelcome" value="1" style="width:18px;height:18px;">
        <span style="color:#555;font-size:0.95rem;">All Jammers Welcome</span>
      </label>
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;margin-bottom:0.5rem;">
        <input type="checkbox" name="BeginnersWelcome" value="1" style="width:18px;height:18px;">
        <span style="color:#555;font-size:0.95rem;">Beginners Welcome</span>
      </label>
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
        <input type="checkbox" name="AdvancedOnly" value="1" style="width:18px;height:18px;">
        <span style="color:#555;font-size:0.95rem;">Advanced Player Jam</span>
      </label>
    </div>
    
    <div style="background:#f5f5f5;padding:1rem;border-radius:5px;">
      <h3 style="margin:0 0 0.75rem 0;color:#225675;font-size:1rem;">Contact Information</h3>
      <input type="text" name="ContactName" placeholder="Your Name *" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;width:100%;margin-bottom:0.75rem;">
      <input type="email" name="ContactEmail" placeholder="Your Email *" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;width:100%;margin-bottom:0.75rem;">
      <input type="tel" name="ContactPhone" placeholder="Your Phone *" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;width:100%;margin-bottom:0.75rem;">
      <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
        <input type="checkbox" name="ShowPhone" value="1" style="width:18px;height:18px;">
        <span style="color:#555;font-size:0.9rem;">Show my phone number publicly on the listing</span>
      </label>
    </div>
    
    <label style="font-weight:600;color:#225675;">City <span style="color:#dc3545;">*</span></label>
    <input type="text" name="City" placeholder="City" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    <label style="font-weight:600;color:#225675;">State <span style="color:#dc3545;">*</span></label>
    <input type="text" name="State" placeholder="State" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    <label style="font-weight:600;color:#225675;">Zip Code <span style="color:#dc3545;">*</span></label>
    <input type="text" name="Zip" placeholder="Zip Code" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    <label style="font-weight:600;color:#225675;">Full Address for Google Maps <span style="color:#dc3545;">*</span></label>
    <input type="text" name="GoogleMapAddress" placeholder="Full Address for Google Maps" required style="padding:0.7rem;border-radius:5px;border:1px solid #ccc;">
    
    <button type="submit" style="padding:0.7rem;background:var(--color-highlight-orange);color:#fff;font-weight:600;border:none;border-radius:5px;cursor:pointer;">Submit Jam</button>
    <p style="color:#888;font-size:0.85rem;margin:0;">* Required fields. Your submission will be reviewed by an admin before being published.</p>
  </form>
</section>

