<% /* Jam Detail Page - BoldWP Structure */ %>
<% layout('layout') %>

<%
  const jamImages = [
    'https://images.lesterslist.com/media/wpic2.jpg',
    'https://images.lesterslist.com/media/general-28.jpg',
    'https://images.lesterslist.com/media/lesterlogo_sq.png'
  ];
  // Stable random image based on JamID (same logic as index)
  const jamImageIndex = (jam.JamID || 0) % jamImages.length;
  const displayImage = jamImages[jamImageIndex];
%>

<article class="boldwp-post-singular boldwp-box detail-page-card" style="max-width:1100px;margin:2.5rem auto 0 auto;width:100%;">
  <div class="boldwp-box-inside">
    <header class="entry-header">
      <div class="entry-header-inside">
        <h1 class="entry-title" style="font-size:2.1rem;margin:0.5rem 0;color:var(--color-secondary-blue);">🎻 <%= jam.JamName %></h1>
      </div>
    </header>
    
    <div class="entry-content" style="display:flex;flex-wrap:wrap;gap:2.5rem;margin-top:1.5rem;">
      <!-- Left: Decorative Image / Badge -->
      <div style="flex:1 1 380px;min-width:280px;display:flex;align-items:flex-start;justify-content:center;">
        <div style="position:relative;width:100%;max-width:453px;">
          <img src="<%= displayImage %>" alt="Local Jam" style="width:100%;height:340px;object-fit:cover;object-position:center;border-radius:10px;background:#f8f9fa;box-shadow:0 2px 8px rgba(34,86,117,0.06);">
          <!-- Jam Type Badge -->
          <div style="position:absolute;top:20px;left:-10px;background:var(--color-primary-teal);color:#fff;padding:0.6rem 1.25rem;border-radius:4px;font-weight:800;font-size:1.1rem;box-shadow:2px 3px 10px rgba(0,0,0,0.2);transform:rotate(-2deg);">
            LOCAL JAM
          </div>
        </div>
      </div>
      
      <!-- Right: Info -->
      <div style="flex:2 1 400px;min-width:260px;">
        <!-- Location (City/State) -->
        <div style="margin-bottom:1.5rem;font-size:1.3rem;color:var(--color-primary-teal);font-weight:600;">
          <%= jam.City %>, <%= jam.State %>
        </div>
        
        <!-- Venue Name -->
        <% if (jam.VenueName) { %>
          <div style="margin-bottom:1.5rem;">
            <h3 class="venue-name" style="font-size:1.5rem;"><%= jam.VenueName %></h3>
          </div>
        <% } %>

        <!-- Schedule -->
        <div style="margin-bottom:1.5rem;background:#f7f9fb;border-radius:8px;padding:1.25rem;border-left:4px solid var(--color-secondary-blue);">
          <div style="font-size:0.85rem;color:#888;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:0.4rem;font-weight:700;">When it happens</div>
          <div style="font-size:1.15rem;color:var(--color-text-main);line-height:1.4;"><%= jam.Schedule %></div>
        </div>
        
        <!-- Welcome Badges -->
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.5rem;">
          <% if (jam.AllWelcome) { %>
            <div style="display:flex;align-items:center;background:#e8f5e9;color:#2e7d32;padding:0.5rem 0.9rem;border-radius:6px;font-size:0.9rem;font-weight:700;">
              <span style="margin-right:0.4rem;">✔</span> ALL WELCOME
            </div>
          <% } %>
          <% if (jam.BeginnersWelcome) { %>
            <div style="display:flex;align-items:center;background:#e3f2fd;color:#1565c0;padding:0.5rem 0.9rem;border-radius:6px;font-size:0.9rem;font-weight:700;">
              <span style="margin-right:0.4rem;">👶</span> BEGINNER FRIENDLY
            </div>
          <% } %>
          <% if (jam.AdvancedOnly) { %>
            <div style="display:flex;align-items:center;background:#fff3e0;color:#e65100;padding:0.5rem 0.9rem;border-radius:6px;font-size:0.9rem;font-weight:700;">
              <span style="margin-right:0.4rem;">⚡</span> ADVANCED ONLY
            </div>
          <% } %>
        </div>

        <!-- Contact Info -->
        <% if (jam.ContactName || jam.ContactEmail || jam.ContactPhone) { %>
          <div style="margin-bottom:1.5rem;font-size:1.05rem;border-top:1px solid #eee;padding-top:1.5rem;">
            <strong style="color:var(--color-text-main);display:block;margin-bottom:0.5rem;">Contact Information:</strong>
            <div style="color:#555;">
              <% if (jam.ContactName) { %><div style="margin-bottom:0.3rem;"><span style="color:#888;width:70px;display:inline-block;">Name:</span> <strong><%= jam.ContactName %></strong></div><% } %>
              <% if (jam.ContactEmail) { %><div style="margin-bottom:0.3rem;"><span style="color:#888;width:70px;display:inline-block;">Email:</span> <a href="mailto:<%= jam.ContactEmail %>" style="color:var(--color-primary-teal);text-decoration:none;"><%= jam.ContactEmail %></a></div><% } %>
              <% if (jam.ContactPhone) { %><div style="margin-bottom:0.3rem;"><span style="color:#888;width:70px;display:inline-block;">Phone:</span> <%= jam.ContactPhone %></div><% } %>
            </div>
          </div>
        <% } %>
        
        <!-- Navigation -->
        <div style="margin-top:2rem;">
          <a href="/jams" style="display:inline-block;color:var(--color-secondary-blue);text-decoration:none;font-weight:700;font-size:1rem;border-bottom:2px solid var(--color-primary-teal);padding-bottom:2px;">
            ← Back to All Jams
          </a>
        </div>
      </div>
    </div>
  </div>
</article>

<!-- Map Section -->
<section class="boldwp-box detail-page-section" style="max-width:1100px;margin:2rem auto 0 auto;width:100%;">
  <div class="boldwp-box-inside">
    <% if (jam.GoogleMapAddress && googleMapsApiKey) { %>
      <div style="display:flex;flex-wrap:wrap;gap:2rem;align-items:flex-start;">
        <div style="flex:2 1 340px;min-width:260px;">
          <iframe
            width="100%"
            height="260"
            style="border:0;border-radius:10px;box-shadow:0 2px 12px rgba(34,86,117,0.08);"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps/embed/v1/place?key=<%= googleMapsApiKey %>&q=<%= encodeURIComponent(jam.GoogleMapAddress) %>">
          </iframe>
        </div>
        <div style="flex:1 1 220px;min-width:180px;color:var(--color-secondary);font-size:1.08rem;">
          <div style="font-weight:700;margin-bottom:0.5rem;color:#225675;">Location</div>
          <div style="color:#444;line-height:1.5;"><%= jam.GoogleMapAddress %></div>
          <div style="margin-top:1.5rem;">
            <a href="https://www.google.com/maps/dir/?api=1&destination=<%= encodeURIComponent(jam.GoogleMapAddress) %>" target="_blank" style="display:inline-block;background:var(--color-primary-teal);color:#fff;padding:0.6rem 1.2rem;border-radius:6px;text-decoration:none;font-weight:700;font-size:0.9rem;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
              🚗 Get Driving Directions
            </a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</section>

<%
  const jamTweet = '🎻 ' + jam.JamName
    + ' — bluegrass jam in ' + jam.City + ', ' + jam.State
    + (jam.VenueName ? ' at ' + jam.VenueName : '')
    + '. ' + jam.Schedule
    + ' #bluegrass #jam';
  const jamShareHref = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(jamTweet) + '&url=' + encodeURIComponent('https://lesterslist.com/jams/' + jam.JamID);
%>
<!-- Share -->
<div style="max-width:1100px;margin:0 auto 0 auto;padding:1rem 0;border-top:1px solid #eee;display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap;">
  <span style="color:#666;font-size:0.85rem;font-weight:600;">Share:</span>
  <a href="<%= jamShareHref %>" target="_blank" rel="noopener" title="Share on X"
     style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;background:#000;border-radius:8px;text-decoration:none;transition:opacity 0.2s;flex-shrink:0;"
     onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="#fff"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.259 5.636L18.244 2.25Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg>
  </a>
  <button onclick="navigator.clipboard.writeText('https://lesterslist.com/jams/<%= jam.JamID %>').then(function(){var t=document.getElementById('share-tip-jam-<%= jam.JamID %>');t.style.opacity='1';setTimeout(function(){t.style.opacity='0'},2000)});" title="Copy link to share on TikTok"
     style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;background:#010101;border-radius:8px;border:none;cursor:pointer;transition:opacity 0.2s;flex-shrink:0;"
     onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="#fff"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.79 1.53V6.77a4.85 4.85 0 0 1-1.02-.08z"/></svg>
  </button>
  <button onclick="navigator.clipboard.writeText('https://lesterslist.com/jams/<%= jam.JamID %>').then(function(){var t=document.getElementById('share-tip-jam-<%= jam.JamID %>');t.style.opacity='1';setTimeout(function(){t.style.opacity='0'},2000)});" title="Copy link to share on Instagram"
     style="display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;background:linear-gradient(45deg,#f09433,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888);border-radius:8px;border:none;cursor:pointer;transition:opacity 0.2s;flex-shrink:0;"
     onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="#fff"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
  </button>
  <span id="share-tip-jam-<%= jam.JamID %>" style="font-size:0.8rem;color:#555;opacity:0;transition:opacity 0.4s;">Link copied!</span>
</div>

<!-- Report a Problem -->
<div class="report-problem" style="max-width:1100px;margin:1rem auto 4rem auto;padding:1.5rem 0;">
  <a href="/report?type=jam&id=<%= jam.JamID %>" style="color:#999;font-size:0.9rem;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:0.5rem;">
    <span>🚩</span> Report a problem with any information on this page
  </a>
</div>
